        <mxCell id="t3" value="&lt;table border=&quot;0&quot; cellspacing=&quot;0&quot; cellpadding=&quot;4&quot; width=&quot;100%&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot;&gt;&lt;b&gt;BackendOps (NEW)&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot;&gt;&lt;font point-size=&quot;9&quot;&gt;connection&lt;br/&gt;backend&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot;&gt;&lt;font point-size=&quot;9&quot;&gt;select_columns(df, select_config)&lt;br/&gt;apply_filters(df, filters)&lt;br/&gt;apply_derive(df, col_name, expr)&lt;br/&gt;union_dataframes(dfs)&lt;br/&gt;drop_duplicates(df, subset)&lt;br/&gt;create_empty_df(columns)&lt;br/&gt;read_delta_or_parquet(path)&lt;br/&gt;join(left, right, on, how)&lt;br/&gt;with_column(df, name, expr)&lt;br/&gt;count(df)&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;rounded=0;strokeColor=#333333;fontFamily=Courier New;fontSize=10;fillColor=#80E0D0;" vertex="1" parent="1">
