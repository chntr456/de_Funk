' ORCHESTRATION
' ══════════════════════════════════════════════════════════
package "Orchestration" #CC99FF {

  class PipelineScheduler {
    - _scheduler
    - _blocking : bool
    --
    + add_job(func, trigger, **trigger_args)
    + start()
    + pause()
    + resume()
    + shutdown()
  }

  class DependencyGraph {
    - _graph : dict
    - _configs_path : Path
    --
    + build()
    + topological_sort() : list[str]
    + filter_buildable(model_names) : list[str]
    + has_circular_dependency() : bool
    + visualize() : str
  }
}

