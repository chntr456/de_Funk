' ══════════════════════════════════════════════════════════
' API LAYER (FastAPI — active, serves Obsidian plugin)
' ══════════════════════════════════════════════════════════
package "API Layer (FastAPI)" #B3D9FF {

  abstract class ExhibitHandler {
    + handles : set[str]
    --
    + {abstract} execute(payload: dict, resolver: Any) : Any
  }

  class HandlerRegistry {
    - _handlers : dict[str, ExhibitHandler]
    + shared_engine : QueryEngine
    --
    + register(handler: ExhibitHandler)
    + get(type_str: str) : ExhibitHandler
    + supported_types : set <<property>>
  }

  class GraphicalHandler {
    + handles : {line, bar, scatter, area, pie, heatmap}
    --
    + execute(payload, resolver) : GraphicalResponse
    - _shape_graphical(rows, has_group, y_count) : GraphicalResponse
  }

  class PivotHandler {
    + handles : {pivot, great_table, gt}
    --
    + execute(payload, resolver) : GreatTablesResponse
    - _row_labels(fields) : list
    - _totals_sql(row_exprs, col_exprs, has_totals) : str
    - _discover_col_values(col_exprs, from, where) : list
    - _generate_wide_sql(...) : str
    - _query_2d_wide(req, rows, cols, measures, ...) : tuple
    - _query_1d(req, rows, measures, ...) : tuple
  }

  class MetricsHandler {
    + handles : {cards.metric, kpi}
    + execute(payload, resolver) : MetricResponse
  }

  class BoxHandler {
    + handles : {box, ohlcv, candlestick}
    + execute(payload, resolver) : dict
  }

  class TableDataHandler {
    + handles : {table.data}
    + execute(payload, resolver) : TableResponse
  }

  class QueryEngine {
    + max_response_mb : float
    + storage_root : Path
    - _conn : duckdb.Connection
    - _delta_available : bool
    - _max_sql_rows : int
    - _max_dimension_values : int
    - _scan_cache : dict
    --
    + _execute(sql, max_rows) : list
    + _scan(path) : str
    + _safe_scan(path) : str
    + {static} _collect_tables(fields) : dict
    + {static} _collect_tables_with_domains(fields) : tuple
    + _build_from(tables, resolver, allowed_domains) : str
    + _build_where(filters, resolver, from_tables) : list
    + _build_order(sort, x_resolved) : str
    + distinct_values(resolved, extra_filters, resolver) : list
    + distinct_values_by_measure(resolved, order_by, order_dir) : list
  }

  class FieldRef {
    - _known_domains : set
    + domain : str
    + field : str
    + raw : str
    --
    + __init__(raw: str)
    + {static} _match_domain(cls, raw) : tuple
  }

  class ResolvedField {
    + ref : FieldRef
    + table_name : str
    + column : str
    + silver_path : Path
    + format_code : Optional[str]
    + domain : str <<property>>
  }

  class FieldResolver {
    - domains_root : Path
    - storage_root : Path
    - _domain_overrides : dict
    - _cache : dict
    - _index : dict
    - _table_columns : dict
    - _join_graph : dict
    - _domain_deps : dict
    - _table_to_domain : dict
    --
    + resolve(ref_str) : ResolvedField
    + resolve_many(refs) : dict
    + find_join_path(src, dst, allowed_domains) : list
    + reachable_domains(core_domains) : set
    + get_field_catalog() : dict
  }

  class BronzeResolver {
    - data_sources_root : Path
    - bronze_root : Path
    - _index : dict
    - _known_providers : set
    --
    + resolve(ref_str) : ResolvedField
    + get_endpoint_catalog() : dict
  }

  ExhibitHandler <|-- GraphicalHandler
  ExhibitHandler <|-- PivotHandler
  ExhibitHandler <|-- MetricsHandler
  ExhibitHandler <|-- BoxHandler
  ExhibitHandler <|-- TableDataHandler

  GraphicalHandler --|> QueryEngine : mixin
  PivotHandler --|> QueryEngine : mixin
  MetricsHandler --|> QueryEngine : mixin
  BoxHandler --|> QueryEngine : mixin
  TableDataHandler --|> QueryEngine : mixin

  HandlerRegistry *-- QueryEngine
}

