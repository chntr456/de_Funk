package "Ingestion" #CC9966 {

  class IngestorEngine {
    + providers : dict
    + sink : BronzeSink
    + progress : BatchProgressTracker
    --
    + run(provider_name, work_items, **kwargs)
    - _process_work_item(provider, work_item)
  }

  class BronzeSink {
    + storage_cfg : dict
    --
    + write_if_missing(table, partitions, df) : bool
    + append_immutable(df, table, key_cols, partitions, date_col) : str
    + upsert(df, table, merge_keys, partitions) : str
  }

  class HttpClient {
    + base_url : str
    - _token_bucket : TokenBucket
    - _circuit_breaker : CircuitBreaker
    --
    + get(path, params) : Response
    - _retry_request(method, url, **kwargs)
  }

  class TokenBucket {
    + rate : float
    + capacity : int
    --
    + acquire(timeout) : bool
    + reset()
  }

  class CircuitBreaker {
    + config : CircuitBreakerConfig
    - _state : str
    --
    + call(fn, *args, **kwargs) : Any
    + reset()
  }

  class ApiKeyPool {
    - _keys : list
    - _current_index : int
    --
    + next_key() : str
    + mark_exhausted(key)
  }

  IngestorEngine *-- BronzeSink
  HttpClient *-- TokenBucket
  HttpClient *-- CircuitBreaker
}

