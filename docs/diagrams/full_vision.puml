' ══════════════════════════════════════════════════════════
' MODEL HIERARCHY (build — uses EngineContext)
' ══════════════════════════════════════════════════════════
package "Model Hierarchy (build)" #FF9933 {

  class BaseModel {
    + ctx : EngineContext
    + model_cfg : dict
    - _dims : dict
    - _facts : dict
    - _built : bool
    --
    + __init__(ctx: EngineContext, model_cfg: dict)
    + build() : tuple[dict, dict]
    + ensure_built()
    + before_build()
    + after_build(dims, facts) : tuple[dict, dict]
    + custom_node_loading(node_id, config) : Optional[DF]
    + write_tables(output_root, format, mode)
    + get_table(name) : Any
    + has_table(name) : bool
    + list_tables() : list[str]
    + get_table_schema(name) : dict
  }

  note right of BaseModel
    ctx replaces:
    - connection (ctx.connection)
    - storage_cfg (ctx.storage_router)
    - repo_root (ctx.repo_root)
    - backend detection (ctx.backend)
    - all if/else branching (ctx.select, ctx.filter, etc.)
    Constructor: 5 params -> 2 params
  end note

  class DomainModel {
    .. default for all domains ..
    + custom_node_loading(node_id, config)
    - _build_seed_node(node_id, config) : DF
    - _build_union_node(node_id, config) : DF
    - _build_distinct_node(node_id, config) : DF
    - _build_window_node(node_id, config) : DF
    - _build_unpivot_node(node_id, config) : DF
    - _create_empty_df(columns) : DF
  }

  note bottom of DomainModel
    Uses ctx.select(), ctx.filter(), ctx.derive(),
    ctx.join(), ctx.union(), ctx.dedup(), ctx.read()
    instead of if backend == spark/duckdb branching
  end note

  class CompanyModel {
    .. hook only ..
    + after_build(dims, facts)
    ' CIK->ticker FK enrichment via ctx.join()
  }

  class TemporalModel {
    .. hook only ..
    + custom_node_loading(node_id, config)
    - _generate_calendar() : DF
    ' Uses ctx.execute_sql() for backend-specific calendar gen
  }

  class TimeSeriesForecastModel {
    + {abstract} get_source_model_name() : str
    + get_training_data(entity_id, date_from, date_to)
    - _prepare_training_data(entity_id, lookback)
  }

  class ForecastModel {
    + get_source_model_name() : str
    + get_source_table_name() : str
    + get_entity_column() : str
    + get_date_column() : str
    + get_training_data(entity_id, date_from, date_to)
    + run_forecast_for_ticker(ticker, config)
  }

  BaseModel <|-- DomainModel
  BaseModel <|-- CompanyModel
  BaseModel <|-- TemporalModel
  BaseModel <|-- TimeSeriesForecastModel
  TimeSeriesForecastModel <|-- ForecastModel
  BaseModel *-- GraphBuilder
  BaseModel *-- ModelWriter
  BaseModel ..> EngineContext : uses ctx
}

' ══════════════════════════════════════════════════════════
' MODEL COMPOSITION
' ══════════════════════════════════════════════════════════
package "Model Composition" #FF9933 {

  class GraphBuilder {
    + model : BaseModel
    --
    + build() : tuple[dict, dict]
    - _build_nodes() : dict[str, DF]
    - _apply_joins(df, join_specs, nodes, node_id) : DF
    - _load_bronze_table(table_name) : DF
    - _load_silver_table(model_name, table_name) : DF
    - _apply_derive(df, col_name, expr, node_id) : DF
    + resolve_node(node_id, nodes) : DF
    __ static __
    + JoinUtils.join_pairs_from_strings(specs)
    + JoinUtils.infer_join_pairs(left, right)
    + JoinUtils.join_with_dedupe(left, right, pairs, how)
  }

  note bottom of GraphBuilder
    All DataFrame ops go through
    model.ctx.select(), model.ctx.join(), etc.
    No direct Spark/DuckDB imports
  end note

  class ModelWriter {
    + model : BaseModel
    + auto_vacuum : bool <<property>>
    --
    + write_tables(dims, facts, root, format, mode)
    - _vacuum_table(path)
  }

  class ModelGraph {
    + graph : nx.DiGraph
    + join_graph : nx.DiGraph
    - _model_configs : dict
    --
    + build_from_registry(registry)
    + are_related(model_a, model_b) : bool
    + get_dependencies(model, transitive) : set
    + get_dependents(model, transitive) : set
    + get_join_path(model_a, model_b) : list
    + get_build_order() : list
    + validate_no_cycles()
    + to_mermaid() : str
  }

  class ModelRegistry {
    - _registry : dict
    - _configs : dict
    --
    + register(name, cls_or_config)
    + get(model_name) : type
    + discover(repo_root)
    + list_models() : list[str]
  }
}

