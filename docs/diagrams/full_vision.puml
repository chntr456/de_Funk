' ══════════════════════════════════════════════════════════
' APP CONFIG
' ══════════════════════════════════════════════════════════
package "App Configuration" #E6E6E6 {
  class ConfigLoader {
    + repo_root : Optional[Path]
    --
    + load(connection_type, log_level) : AppConfig
    - _discover_repo_root(start) : Path
  }

  class AppConfig <<dataclass>> {
    + repo_root : Path
    + connection : ConnectionConfig
    + storage : StorageConfig
    + apis : dict[str, APIConfig]
    + debug : DebugConfig
  }

  class ConnectionFactory {
    + {static} create(connection_type, **kwargs) : DataConnection
    + {static} get_spark_connection(session) : SparkConnection
    + {static} get_duckdb_connection(db_path, **kwargs) : DuckDBConnection
  }
}

