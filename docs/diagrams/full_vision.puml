@startuml "de_Funk Full Vision — Target Architecture"

skinparam classFontName "Courier New"
skinparam classFontSize 10
skinparam packageFontSize 12
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam style strictuml

title de_Funk Full Vision — Target Architecture\nEngine/Session pattern. Typed data classes. Three paths.

note as ThreePaths
  | Path | Reads | Writes | Config Needed |
  | **Ingestion** | External APIs | Raw + Bronze | ProviderConfig + EndpointConfig |
  | **Build** | Bronze + Silver | Silver | DomainModelConfig + SourceConfig |
  | **Query** | Silver (+ Bronze) | nothing | DomainModelConfig (tables, graph, measures) |
end note

' ══════════════════════════════════════════════════════════
' DOMAIN DATA CLASSES
' ══════════════════════════════════════════════════════════
package "Domain Data Classes" #FFCC66 {

  class SchemaField <<dataclass>> {
    + name : str
    + type : str
    + nullable : bool
    + description : str
    + derived : Optional[str]
    + fk : Optional[str]
    + format : Optional[str]
  }

  class EdgeSpec <<dataclass>> {
    + name : str
    + from_table : str
    + to_table : str
    + join_keys : list[str]
    + cardinality : str
    + target_domain : Optional[str]
    + optional : bool
  }

  class MeasureDef <<dataclass>> {
    + name : str
    + aggregation : str
    + field : str | dict
    + label : str
    + format : Optional[str]
    + options : dict
  }

  class AliasSpec <<dataclass>> {
    + target_column : str
    + expression : str
  }

  class EnrichSpec <<dataclass>> {
    + from_table : str
    + join : list[str]
    + columns : list[str]
  }

  class TableConfig <<dataclass>> {
    + table : str
    + table_type : str
    + schema : list[SchemaField]
    + primary_key : list[str]
    + unique_key : list[str]
    + partition_by : list[str]
    + measures : list[MeasureDef]
    + enrich : list[EnrichSpec]
    + pipeline : list[PipelineStep]
    + extends : Optional[str]
  }

  class SourceConfig <<dataclass>> {
    + source : str
    + maps_to : str
    + from_ref : str
    + aliases : list[AliasSpec]
    + domain_source : Optional[str]
    + filter : list[str]
    + extends : Optional[str]
  }

  class GraphSpec <<dataclass>> {
    + edges : list[EdgeSpec]
    + paths : dict[str, Any]
  }

  class ModelStorageSpec <<dataclass>> {
    + format : str
    + silver_root : Optional[str]
  }

  class PhaseSpec <<dataclass>> {
    + tables : list[str]
  }

  class BuildSpec <<dataclass>> {
    + sort_by : list[str]
    + optimize : bool
    + partitions : list[str]
    + phases : dict[str, PhaseSpec]
  }

  BuildSpec *-- PhaseSpec : phases

  class MeasuresSpec <<dataclass>> {
    + simple : list[MeasureDef]
    + computed : list[MeasureDef]
  }

  class HookDef <<dataclass>> {
    + fn : str
    + params : dict
  }

  class PipelineStep <<dataclass>> {
    + op : str
    + fn : Optional[str]
    + params : dict
  }

  class HooksConfig <<dataclass>> {
    + pre_build : list[HookDef]
    + before_build : list[HookDef]
    + after_build : list[HookDef]
    + post_build : list[HookDef]
  }

  class DomainModelConfig <<dataclass>> {
    + model : str
    + version : str
    + description : str
    + extends : list[str]
    + depends_on : list[str]
    + status : str
    + storage : ModelStorageSpec
    + graph : GraphSpec
    + build : BuildSpec
    + measures : MeasuresSpec
    + hooks : HooksConfig
    + metadata : dict
    --
    + tables : dict[str, TableConfig]
    + sources : dict[str, SourceConfig]
    + views : dict[str, Any]
  }

  DomainModelConfig *-- ModelStorageSpec : storage
  DomainModelConfig *-- GraphSpec : graph
  DomainModelConfig *-- BuildSpec : build
  DomainModelConfig *-- MeasuresSpec : measures
  DomainModelConfig *-- HooksConfig : hooks
  DomainModelConfig *-- TableConfig : tables
  DomainModelConfig *-- SourceConfig : sources
  HooksConfig *-- HookDef : hook definitions
  TableConfig *-- PipelineStep : pipeline steps
  TableConfig *-- SchemaField : schema columns
  TableConfig *-- MeasureDef : table measures
  TableConfig *-- EnrichSpec : enrichments
  SourceConfig *-- AliasSpec : field aliases
  GraphSpec *-- EdgeSpec : join edges
  MeasuresSpec *-- MeasureDef : definitions
