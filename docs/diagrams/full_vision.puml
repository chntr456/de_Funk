    + providers : dict[str, dict]
    + silver_models : list[str]
    + cluster : ClusterConfig
    + retry : RetryConfig
    + profiles : dict[str, dict]
  }

  StorageConfig *-- RootsConfig
  StorageConfig *-- ApiLimits
  StorageConfig *-- TablePath
  RunConfig *-- ClusterConfig
  RunConfig *-- RetryConfig
}

' ══════════════════════════════════════════════════════════
' ENGINE CONTEXT (operates on typed data classes)
' ══════════════════════════════════════════════════════════
package "Engine Context (initialized system state — NOT a god object)" #80E0D0 {

  note as CtxNote
    Container of ready-to-use objects. Has no logic itself.
    DOES: Hold references to configs, resolver, connection, ops.
    DOES NOT: Load configs, build graphs, execute SQL, build models.
    Flat API (ctx.join, ctx.filter) delegates to internal _ops/_sql.
  end note

  class EngineContext {
    .. shared infrastructure ..
    + storage : StorageConfig
    + conn : DataConnection
    + backend : str
    + repo_root : Path
    .. private strategy ..
    - _ops : DataOps
    - _sql : SqlOps
    --
    .. DataFrame ops (delegates to _ops) ..
    + select(df, columns) : Any
    + filter(df, filters) : Any
    + derive(df, col, expr) : Any
    + join(left, right, on, how) : Any
    + union(dfs) : Any
    + dedup(df, subset) : Any
    + read(path) : Any
    + write(df, path, format, mode) : Any
    + count(df) : int
    + to_pandas(df) : DataFrame
    .. SQL ops (delegates to _sql) ..
    + execute_sql(sql) : Any
    + scan(path) : str
    --
    + {static} for_spark(spark, storage) : EngineContext
    + {static} for_duckdb(duckdb_path, storage) : EngineContext
  }

  class IngestContext {
    .. Ingestion path: reads APIs, writes Raw + Bronze ..
    + engine : EngineContext
    + providers : dict[str, ProviderConfig]
    + endpoints : dict[str, EndpointConfig]
    + run : RunConfig
    --
    + get_provider(provider_id) : ProviderConfig
    + get_endpoint(provider_id, endpoint_id) : EndpointConfig
    + raw_path(provider, endpoint) : str
    + bronze_path(provider, endpoint) : str
  }

  class BuildContext {
    .. Build path: reads Bronze+Silver, writes Silver ..
    + engine : EngineContext
    + models : dict[str, DomainModelConfig]
    + loader : DomainConfigLoader
    + date_from : str
    + date_to : str
    + max_tickers : Optional[int]
    + dry_run : bool
    --
    + get_model(model_name) : DomainModelConfig
    + get_dependencies(model_name) : list[str]
    + silver_path(domain, model) : str
    + bronze_path(provider, endpoint) : str
  }

  class QueryContext {
    .. Query path: reads Silver (+Bronze), writes nothing ..
    + engine : EngineContext
    + models : dict[str, DomainModelConfig]
    + resolver : FieldResolver
    + storage_router : StorageRouter
    --
    + resolve(ref_str) : ResolvedField
    + find_join_path(src, dst) : list
    + distinct_values(resolved) : list
    + build_from(tables, allowed_domains) : str
    + build_where(filters) : str
  }

  abstract class DataOps <<internal>> {
    + {abstract} select(df, columns) : Any
    + {abstract} filter(df, filters) : Any
    + {abstract} derive(df, col, expr) : Any
    + {abstract} join(left, right, on, how) : Any
    + {abstract} union(dfs) : Any
    + {abstract} dedup(df, subset) : Any
    + {abstract} read(path) : Any
    + {abstract} write(df, path, format, mode) : Any
    + {abstract} count(df) : int
    + {abstract} to_pandas(df) : DataFrame
  }

  abstract class SqlOps <<internal>> {
    + {abstract} execute_sql(sql, max_rows) : list
    + {abstract} scan(path) : str
    + {abstract} build_from(tables, resolver) : str
    + {abstract} build_where(filters) : str
    + {abstract} distinct_values(resolved) : list
  }

  class DuckDBOps <<internal>> {
    - _conn : duckdb.Connection
    - _scan_cache : dict
    --
    .. DuckDB implementations ..
  }

  class SparkOps <<internal>> {
    - _spark_session
    --
    .. Spark implementations ..
  }

  class DuckDBSql <<internal>> {
    - _conn : duckdb.Connection
    --
    .. DuckDB SQL generation ..
  }

  class SparkSql <<internal>> {
    - _spark_session
    --
    .. Spark SQL generation ..
  }

  EngineContext *-- DataOps : _ops
  EngineContext *-- SqlOps : _sql
  DataOps <|-- DuckDBOps
  DataOps <|-- SparkOps
  SqlOps <|-- DuckDBSql
  SqlOps <|-- SparkSql

  IngestContext *-- EngineContext : engine
  IngestContext *-- ProviderConfig : holds many
  IngestContext *-- EndpointConfig : holds many
  IngestContext *-- RunConfig

  BuildContext *-- EngineContext : engine
  BuildContext *-- DomainModelConfig : holds many

  QueryContext *-- EngineContext : engine
  QueryContext *-- DomainModelConfig : holds many
  QueryContext *-- FieldResolver
  QueryContext *-- StorageRouter

  note right of EngineContext
    Shared base: connection + backend-agnostic ops.
    No configs, no domain knowledge.
    Sub-contexts add path-specific state:
      IngestContext: providers + endpoints
      BuildContext: models + sources + date range
      QueryContext: models + resolver + storage router
  end note
}

' ══════════════════════════════════════════════════════════
' FIELD RESOLUTION (lives on EngineContext, shared by build + query)
' ══════════════════════════════════════════════════════════
package "Field Resolution" #80E0D0 {

  class FieldRef {
    - _known_domains : set
    + domain : str
    + field : str
    + raw : str
    --
    + __init__(raw: str)
    + {static} _match_domain(cls, raw) : tuple
  }

  class ResolvedField {
    + ref : FieldRef
    + table_name : str
    + column : str
    + silver_path : Path
    + format_code : Optional[str]
    + domain : str <<property>>
  }

  class FieldResolver {
    - _cache : dict
    - _index : dict
    - _table_columns : dict
    - _join_graph : dict
    - _domain_deps : dict
    - _table_to_domain : dict
    --
    + __init__(ctx: EngineContext)
    - _build_index()
    + reachable_domains(core_domains) : set
    + find_join_path(src, dst, allowed_domains) : list
    + resolve(ref_str) : ResolvedField
    + resolve_many(refs) : dict
    + get_field_catalog() : dict
  }

  class StorageRouter <<frozen dataclass>> {
    + storage_cfg : dict
    + repo_root : Optional[Path]
    .. mount points (different physical storage) ..
    + raw_root : Path
    + bronze_root : Path
    + silver_root : Path
    --
    + parse_table_ref(table_ref) : tuple
    + resolve(table_ref) : str
    + raw_path(provider, endpoint) : str
    + bronze_path(provider, endpoint) : str
    + silver_path(domain, model) : str
  }

  note bottom of StorageRouter
    Raw: HDD/NAS (bulk, cheap, archival)
      /mnt/disk/storage/raw/{provider}/{endpoint}/
    Bronze + Silver: SSD (fast Delta Lake scans)
      /shared/storage/bronze/{provider}/{endpoint}/
      /shared/storage/silver/{domain}/{model}/
    Mount points configured in storage.json
  end note

  class Aggregator {
    + {static} aggregate(ctx: EngineContext, df, group_by, aggs) : Any
    + {static} infer_aggregations(model_name, cols, registry) : dict
    + {static} default_aggregation(column_name) : str
  }

  class JoinPlanner {
    + ctx : EngineContext
    --
    + build_column_index(model_name) : dict
    + find_materialized_view(model, required_cols) : str
    + plan_auto_joins(model, base_table, missing_cols, filters) : dict
    + execute_auto_joins(model, plan, cols, filters, group_by, aggs)
    - _build_where_clause(filters, base, available_cols) : str
    - _parse_join_condition(condition) : tuple
  }

  FieldResolver ..> EngineContext : reads config from
  JoinPlanner ..> FieldResolver : uses join graph
  EngineContext *-- StorageRouter
  EngineContext *-- FieldResolver
  EngineContext *-- JoinPlanner
}

' ══════════════════════════════════════════════════════════
' CONFIG LOADING
' ══════════════════════════════════════════════════════════
package "Config Loading (parse files -> produce data classes)" #FFCC66 {

  class DomainConfigLoader {
    - domains_dir : Path
    - _type_index : dict
    - _model_to_path : dict
    - _parse_cache : dict
    --
    + load_model_config(model_name) : dict
    - _discover_tables(model_dir) : dict
    - _discover_sources(model_dir) : dict
    - _discover_views(model_dir) : dict
  }

  class config_translator <<module>> {
    + {static} translate_domain_config(config) : dict
    - {static} _synthesize_node(table_name, table_cfg, sources) : dict
    - {static} _build_node_from_source(table_cfg, source) : dict
    - {static} _normalize_from(from_spec) : str
    - {static} _aliases_to_select_dict(aliases) : dict
    - {static} _enrich_to_join_specs(table_config) : list
  }

  class extends_resolver <<module>> {
    + {static} parse_front_matter(file_path) : dict
    + {static} deep_merge(base, override) : dict
    + {static} resolve_extends_reference(ref, dir, cache) : dict
    + {static} resolve_nested_extends(config, dir, cache) : dict
  }

  DomainConfigLoader ..> config_translator : uses
  DomainConfigLoader ..> extends_resolver : uses
  EngineContext *-- DomainConfigLoader
}

' ══════════════════════════════════════════════════════════
' CONNECTION HIERARCHY
' ══════════════════════════════════════════════════════════
package "Connection Hierarchy" #E6E6E6 {

  abstract class DataConnection {
    + {abstract} read_table(path, format) : Any
    + {abstract} apply_filters(df, filters) : Any
    + {abstract} to_pandas(df) : DataFrame
    + {abstract} count(df) : int
    + {abstract} cache(df) : Any
    + {abstract} uncache(df)
    + {abstract} stop()
  }

  class DuckDBConnection #3399FF {
    + conn : duckdb.Connection
    + db_path : str
    + delta_enabled : bool
    --
    + read_table(path, format, version, timestamp)
    + execute_sql(query) : Any
    + read_parquet(path) : Any
    + write_delta_table(df, path, mode, partition_by)
    + apply_filters(df, filters) : Any
    + to_pandas(df) : DataFrame
    + count(df) : int
    + table(view_name) : Any
    + has_view(view_name) : bool
  }

  class SparkConnection #FF9933 {
    + spark_session
    --
    + read_table(path, format, version, timestamp)
    + write_delta_table(df, path, mode, partition_by)
    + merge_delta_table(source_df, target_path, condition)
    + optimize_delta_table(path, zorder_by)
    + vacuum_delta_table(path, retention_hours)
    + apply_filters(df, filters) : Any
    + to_pandas(df) : DataFrame
    + count(df) : int
  }

  DataConnection <|-- DuckDBConnection
  DataConnection <|-- SparkConnection
  EngineContext *-- DataConnection : holds one
}

' ══════════════════════════════════════════════════════════
' MODEL HIERARCHY (build — uses EngineContext)
' ══════════════════════════════════════════════════════════
package "Model Hierarchy (build)" #FF9933 {

  class BaseModel {
    + ctx : BuildContext
    + config : DomainModelConfig
    - _dims : dict
    - _facts : dict
    - _built : bool
    --
    + __init__(ctx: BuildContext, config: DomainModelConfig)
    + build() : tuple[dict, dict]
    + ensure_built()
    + before_build()
    + after_build(dims, facts) : tuple[dict, dict]
    + custom_node_loading(node_id, config) : Optional[DF]
    + write_tables(output_root, format, mode)
    + get_table(name) : Any
    + has_table(name) : bool
    + list_tables() : list[str]
    + get_table_schema(name) : dict
  }

  note right of BaseModel
    Takes BuildContext (build path state) +
    DomainModelConfig (typed YAML, not raw dict).
    Reads Bronze + Silver from dependencies.
    Writes Silver tables.
  end note

  class DomainModel {
    .. default for all domains ..
    + custom_node_loading(node_id, config)
    - _build_seed_node(node_id, config) : DF
    - _build_union_node(node_id, config) : DF
    - _build_distinct_node(node_id, config) : DF
    - _build_window_node(node_id, config) : DF
    - _build_unpivot_node(node_id, config) : DF
    - _create_empty_df(columns) : DF
  }

  note bottom of DomainModel
    Uses ctx.select(), ctx.filter(), ctx.derive(),
    ctx.join(), ctx.union(), ctx.dedup(), ctx.read()
    instead of if backend == spark/duckdb branching
  end note

  class CompanyModel {
    .. hook only ..
    + after_build(dims, facts)
    ' CIK->ticker FK enrichment via ctx.join()
  }

  class TemporalModel {
    .. hook only ..
    + custom_node_loading(node_id, config)
    - _generate_calendar() : DF
    ' Uses ctx.execute_sql() for backend-specific calendar gen
  }

  class TimeSeriesForecastModel {
    + {abstract} get_source_model_name() : str
    + get_training_data(entity_id, date_from, date_to)
    - _prepare_training_data(entity_id, lookback)
  }

  class ForecastModel {
    + get_source_model_name() : str
    + get_source_table_name() : str
    + get_entity_column() : str
    + get_date_column() : str
    + get_training_data(entity_id, date_from, date_to)
    + run_forecast_for_ticker(ticker, config)
  }

  BaseModel <|-- DomainModel
  BaseModel <|-- CompanyModel
  BaseModel <|-- TemporalModel
  BaseModel <|-- TimeSeriesForecastModel
  TimeSeriesForecastModel <|-- ForecastModel
  BaseModel *-- GraphBuilder
  BaseModel *-- ModelWriter
  BaseModel ..> BuildContext : uses ctx
}

' ══════════════════════════════════════════════════════════
' MODEL COMPOSITION
' ══════════════════════════════════════════════════════════
package "Model Composition" #FF9933 {

  class GraphBuilder {
    + model : BaseModel
    --
    + build() : tuple[dict, dict]
    - _build_nodes() : dict[str, DF]
    - _apply_joins(df, join_specs, nodes, node_id) : DF
    - _load_bronze_table(table_name) : DF
    - _load_silver_table(model_name, table_name) : DF
    - _apply_derive(df, col_name, expr, node_id) : DF
    + resolve_node(node_id, nodes) : DF
    __ static __
    + JoinUtils.join_pairs_from_strings(specs)
    + JoinUtils.infer_join_pairs(left, right)
    + JoinUtils.join_with_dedupe(left, right, pairs, how)
  }

  note bottom of GraphBuilder
    All DataFrame ops go through
    model.ctx.select(), model.ctx.join(), etc.
    No direct Spark/DuckDB imports
  end note

  class ModelWriter {
    + model : BaseModel
    + auto_vacuum : bool <<property>>
    --
    + write_tables(dims, facts, root, format, mode)
    - _vacuum_table(path)
  }

  class ModelGraph {
    + graph : nx.DiGraph
    + join_graph : nx.DiGraph
    - _model_configs : dict
    --
    + build_from_registry(registry)
    + are_related(model_a, model_b) : bool
    + get_dependencies(model, transitive) : set
    + get_dependents(model, transitive) : set
    + get_join_path(model_a, model_b) : list
    + get_build_order() : list
    + validate_no_cycles()
    + to_mermaid() : str
  }

  class ModelRegistry {
    - _registry : dict
    - _configs : dict
    --
    + register(name, cls_or_config)
    + get(model_name) : type
    + discover(repo_root)
    + list_models() : list[str]
  }
}

' ══════════════════════════════════════════════════════════
' BRONZE RESOLUTION (separate data source, same resolve interface)
' ══════════════════════════════════════════════════════════
package "Bronze Resolution" #CC9966 {

  class BronzeResolver {
    + ctx : EngineContext
    - _index : dict
    - _known_providers : set
    - _cache : dict
    --
    + resolve(ref_str) : ResolvedField
    - _build_index()
    + reachable_domains(core_domains) : set
    + get_endpoint_catalog() : dict
  }
}

' ══════════════════════════════════════════════════════════
' HANDLER HIERARCHY (API — uses EngineContext)
' ══════════════════════════════════════════════════════════
package "Handler Hierarchy (API)" #B3D9FF {

  abstract class ExhibitHandler {
    + handles : set[str]
    + ctx : QueryContext
    --
    + {abstract} execute(payload: dict, resolver: Any) : Any
  }

  class HandlerRegistry {
    - _handlers : dict
    + ctx : QueryContext
    --
    + register(handler)
    + get(type_str) : ExhibitHandler
    + supported_types : set <<property>>
  }

  class GraphicalHandler {
    + handles : {line, bar, scatter, area, pie, heatmap}
    --
    + execute(payload, resolver) : GraphicalResponse
    - _shape_graphical(rows, has_group, y_count) : GraphicalResponse
  }

  class PivotHandler {
    + handles : {pivot, great_table, gt}
    --
    + execute(payload, resolver) : GreatTablesResponse
    - _row_labels(fields) : list
    - _totals_sql(row_exprs, col_exprs, has_totals) : str
    - _discover_col_values(col_exprs, from, where) : list
    - _generate_wide_sql(...) : str
    - _query_2d_wide(req, rows, cols, measures, ...) : tuple
    - _query_1d(req, rows, measures, ...) : tuple
  }

  class MetricsHandler {
    + handles : {cards.metric, kpi}
    + execute(payload, resolver) : MetricResponse
  }

  class BoxHandler {
    + handles : {box, ohlcv, candlestick}
    + execute(payload, resolver) : dict
  }

  class TableDataHandler {
    + handles : {table.data}
    + execute(payload, resolver) : TableResponse
  }

  ExhibitHandler <|-- GraphicalHandler
  ExhibitHandler <|-- PivotHandler
  ExhibitHandler <|-- MetricsHandler
  ExhibitHandler <|-- BoxHandler
  ExhibitHandler <|-- TableDataHandler

  ExhibitHandler ..> QueryContext : uses ctx
}

' ══════════════════════════════════════════════════════════
' BUILDER HIERARCHY (uses EngineContext via BuildContext)
' ══════════════════════════════════════════════════════════
package "Builder Hierarchy" #FF9933 {

  abstract class BaseModelBuilder {
    + model_name : str
    + depends_on : list[str]
    + context : BuildContext
    --
    + {abstract} get_model_class() : Type
    + validate()
    + pre_build()
    + post_build(result)
    + build() : BuildResult
  }

  class BuildContext {
    + ctx : EngineContext
    + date_from : str
    + date_to : str
    + max_tickers : Optional[int]
    + dry_run : bool
    + verbose : bool
  }

  note right of BuildContext
    Replaces: spark, storage_config, repo_root
    All absorbed into ctx: EngineContext
  end note

  class BuildResult {
    + model_name : str
    + success : bool
    + dimensions : dict
    + facts : dict
    + rows_written : int
    + duration_seconds : float
    + error : str
    + warnings : list
  }

  class DomainBuilderFactory {
    + CUSTOM_MODEL_CLASSES : dict
    --
    + {static} create_builders(domains_dir, repo_root) : dict
    - {static} _create_builder_class(model_name, config, loader) : type
  }

  class TemporalBuilder {
    + depends_on : none
    + get_model_class() : TemporalModel
  }

  class SecuritiesBuilder {
    + depends_on : temporal
    + get_model_class() : DomainModel
  }

  class StocksBuilder {
    + depends_on : temporal, securities, corporate
    + get_model_class() : DomainModel
    + post_build(result)
  }

  class CompanyBuilder {
    + depends_on : temporal
    + get_model_class() : CompanyModel
    + post_build(result)
  }

  class ForecastBuilder {
    + depends_on : temporal, stocks
    + get_model_class() : ForecastModel
    + build() : BuildResult
    + validate() : bool
  }

  BaseModelBuilder <|-- TemporalBuilder
  BaseModelBuilder <|-- SecuritiesBuilder
  BaseModelBuilder <|-- StocksBuilder
  BaseModelBuilder <|-- CompanyBuilder
  BaseModelBuilder <|-- ForecastBuilder

  BuildContext *-- EngineContext
}

' ══════════════════════════════════════════════════════════
' PROVIDER HIERARCHY (ingestion — uses EngineContext for paths)
' ══════════════════════════════════════════════════════════
package "Provider Hierarchy (ingestion)" #CC9966 {

  abstract class BaseProvider {
    + provider_name : str
    + ctx : EngineContext
    --
    + {abstract} list_work_items(**kwargs) : list
    + {abstract} fetch(work_item, **kwargs) : Generator
    + {abstract} normalize(records, work_item) : DF
    + {abstract} get_table_name(work_item) : str
  }

  class AlphaVantageProvider {
    - api_keys : list
    - _key_pool : ApiKeyPool
    --
    + fetch(ticker) : Generator
    + normalize(records, ticker) : DF
    + list_work_items(tickers) : list
  }

  class SocrataBaseProvider {
    - _client : SocrataClient
    + fetch(endpoint) : Generator
    - _paginate(endpoint, limit, offset)
    - _transform_dates(records) : list
  }

  class ChicagoProvider {
    .. extends SocrataBaseProvider ..
  }

  class CookCountyProvider {
    .. extends SocrataBaseProvider ..
    - _get_endpoint_config() : dict
  }

  BaseProvider <|-- AlphaVantageProvider
  BaseProvider <|-- SocrataBaseProvider
  SocrataBaseProvider <|-- ChicagoProvider
  SocrataBaseProvider <|-- CookCountyProvider
}

' ══════════════════════════════════════════════════════════
' INGESTION ENGINE
' ══════════════════════════════════════════════════════════
package "Ingestion Pipeline" #CC9966 {

  class IngestorEngine {
    + providers : dict
    + raw_sink : RawSink
    + bronze_sink : BronzeSink
    + progress : BatchProgressTracker
    --
    + run(provider_name, work_items, **kwargs)
    - _process_work_item(provider, work_item)
  }

  class RawSink {
    .. downloads -> raw files (CSV, JSON, API responses) ..
    + raw_root : Path
    --
    + write(data: bytes, provider: str, endpoint: str, partition: str) : Path
    + exists(provider: str, endpoint: str, partition: str) : bool
    + read(provider: str, endpoint: str, partition: str) : Any
    + list_partitions(provider: str, endpoint: str) : list
  }

  note bottom of RawSink
    HDD/NAS mount (bulk, cheap):
    /mnt/disk/storage/raw/{provider}/{endpoint}/{partition}/
    Preserves original downloaded data.
    Re-ingestion reads from Raw, not from API.
  end note

  class BronzeSink {
    .. raw files -> typed Delta Lake tables ..
    + ctx : EngineContext
    --
    + write_if_missing(table, partitions, df) : bool
    + append_immutable(df, table, key_cols, partitions, date_col) : str
    + upsert(df, table, merge_keys, partitions) : str
    + rebuild_from_raw(provider: str, endpoint: str) : str
  }

  note bottom of BronzeSink
    SSD mount (fast Delta scans):
    /shared/storage/bronze/{provider}/{endpoint}/
    Reads from Raw (HDD), applies schema, writes Delta (SSD).
    Can rebuild Bronze from Raw without re-downloading.
  end note

  class HttpClient {
    + base_url : str
    - _token_bucket : TokenBucket
    - _circuit_breaker : CircuitBreaker
    --
    + get(path, params) : Response
    - _retry_request(method, url, **kwargs)
  }

  class TokenBucket {
    + rate : float
    + capacity : int
    --
    + acquire(timeout) : bool
    + reset()
  }

  class CircuitBreaker {
    + config : CircuitBreakerConfig
    - _state : str
    --
    + call(fn, *args, **kwargs) : Any
    + reset()
    + state : str <<property>>
  }

  class ApiKeyPool {
    - _keys : list
    - _current_index : int
    --
    + next_key() : str
    + mark_exhausted(key)
  }

  IngestorEngine *-- RawSink
  IngestorEngine *-- BronzeSink
  RawSink ..> BronzeSink : feeds
  HttpClient *-- TokenBucket
  HttpClient *-- CircuitBreaker
}

