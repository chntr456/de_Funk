' CONNECTION HIERARCHY
' ══════════════════════════════════════════════════════════
package "Connections" #E6E6E6 {

  interface DataConnection <<interface>> {
    + read_table(path, format) : Any
    + apply_filters(df, filters) : Any
    + to_pandas(df) : DataFrame
    + count(df) : int
    + cache(df) : Any
    + stop()
  }

  class DuckDBConnection {
    + conn : duckdb.Connection
    + db_path : str
    + delta_enabled : bool
    --
    + read_table(path, format, version, timestamp)
    + execute_sql(query) : Any
    + write_delta_table(df, path, mode, partition_by)
    + apply_filters(df, filters) : Any
    + to_pandas(df) : DataFrame
    + count(df) : int
  }

  class SparkConnection {
    + spark_session
    --
    + read_table(path, format, version, timestamp)
    + write_delta_table(df, path, mode, partition_by)
    + merge_delta_table(source_df, target_path, condition)
    + apply_filters(df, filters) : Any
    + to_pandas(df) : DataFrame
    + count(df) : int
  }

  DataConnection <|.. DuckDBConnection
  DataConnection <|.. SparkConnection
  Engine *-- DataConnection : conn
}

