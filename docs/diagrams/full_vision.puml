@startuml "de_Funk Full Vision — Target Architecture"

skinparam classAttributeIconSize 0
skinparam classFontName "Courier New"
skinparam classFontSize 10
skinparam packageFontSize 12
skinparam packageStyle rectangle
skinparam linetype ortho

title de_Funk Full Vision — Target Architecture\nEngineContext is the universal runtime. The model IS the markdown.

' ══════════════════════════════════════════════════════════
' ENGINE CONTEXT (the universal runtime — replaces all parameter threading)
' ══════════════════════════════════════════════════════════
package "Engine Context (universal runtime)" #80E0D0 {

  class EngineContext {
    .. identity ..
    + repo_root : Path
    + app_config : AppConfig
    .. connection (created once) ..
    + connection : DataConnection
    + backend : str
    - _engine : Engine
    .. paths (created once from storage.json) ..
    + storage_router : StorageRouter
    + bronze_root : Path
    + silver_root : Path
    + domains_root : Path
    .. resolution (created once from domain configs) ..
    + field_resolver : FieldResolver
    + domain_loader : DomainConfigLoader
    + registry : ModelRegistry
    --
    .. DataFrame ops (delegated to _engine) ..
    + select(df, columns: dict) : Any
    + filter(df, filters: list) : Any
    + derive(df, col: str, expr: str) : Any
    + join(left, right, on: list, how: str) : Any
    + union(dfs: list) : Any
    + dedup(df, subset: list) : Any
    + read(path: str) : Any
    + write(df, path: str, format: str, mode: str) : Any
    + empty_df(columns: list) : Any
    + count(df) : int
    + to_pandas(df) : DataFrame
    .. SQL ops (delegated to _engine) ..
    + execute_sql(sql: str) : Any
    + scan(path: str) : str
    + build_from(tables, resolver, allowed_domains) : str
    + build_where(filters: list) : str
    + build_order(sort, x_resolved) : str
    + distinct_values(resolved, extra_filters, resolver) : list
    + distinct_values_by_measure(resolved, order_by, dir) : list
    .. model ops (absorbed from QuerySession) ..
    + load_model(model_name) : BaseModel
    + get_table(model_name, table_name, columns, filters) : Any
    + list_models() : list[str]
    + list_tables(model_name) : dict
    + get_model_metadata(model_name) : dict
    --
    + {static} from_config(config: AppConfig) : EngineContext
    + {static} for_build(spark, storage_cfg, repo_root) : EngineContext
    + {static} for_query(duckdb_path, storage_cfg, repo_root) : EngineContext
  }

  abstract class Engine <<internal>> {
    .. strategy interface (private to EngineContext) ..
    + {abstract} execute_sql(sql, max_rows) : list
    + {abstract} scan(path) : str
    + {abstract} read_table(path) : Any
    + {abstract} select(df, columns) : Any
    + {abstract} filter(df, filters) : Any
    + {abstract} derive(df, col, expr) : Any
    + {abstract} join(left, right, on, how) : Any
    + {abstract} union(dfs) : Any
    + {abstract} dedup(df, subset) : Any
    + {abstract} write(df, path, format, mode) : Any
    + {abstract} count(df) : int
    + {abstract} to_pandas(df) : DataFrame
    + {abstract} build_from(tables, resolver) : str
    + {abstract} build_where(filters) : str
    + {abstract} distinct_values(resolved) : list
  }

  class DuckDBEngine <<internal>> {
    - _conn : duckdb.Connection
    - _scan_cache : dict
    - _delta_available : bool
    - _max_sql_rows : int
    --
    .. implements Engine for DuckDB ..
    + execute_sql(sql, max_rows) : list
    + scan(path) : str
    + safe_scan(path) : str
    + build_from(tables, resolver, allowed_domains) : str
    + build_where(filters, resolver, from_tables) : list
    + distinct_values(resolved, extra_filters, resolver) : list
    + distinct_values_by_measure(resolved, order_by, dir) : list
  }

  class SparkEngine <<internal>> {
    - _spark_session
    --
    .. implements Engine for Spark ..
    + execute_sql(sql, max_rows) : list
    + read_table(path) : SparkDF
    + build_from(tables, resolver) : str
    + build_where(filters, resolver) : list
    + distinct_values(resolved, extra_filters, resolver) : list
  }

  EngineContext *-- Engine : _engine (private)
  Engine <|-- DuckDBEngine
  Engine <|-- SparkEngine

  note right of EngineContext
    Absorbs QuerySession:
    - load_model, get_table, list_models (model-aware queries)
    Absorbs FilterEngine + BackendOps:
    - filter, select, derive, join, union, dedup
    Contains Engine strategy (private):
    - DuckDBEngine or SparkEngine selected at creation
    - All 113 backend branches resolved internally
    Created once, passed everywhere as ctx
  end note
}

' ══════════════════════════════════════════════════════════
' FIELD RESOLUTION (lives on EngineContext, shared by build + query)
' ══════════════════════════════════════════════════════════
package "Field Resolution" #80E0D0 {

  class FieldRef {
    - _known_domains : set
    + domain : str
    + field : str
    + raw : str
    --
    + __init__(raw: str)
    + {static} _match_domain(cls, raw) : tuple
  }

  class ResolvedField {
    + ref : FieldRef
    + table_name : str
    + column : str
    + silver_path : Path
    + format_code : Optional[str]
    + domain : str <<property>>
  }

  class FieldResolver {
    - _cache : dict
    - _index : dict
    - _table_columns : dict
    - _join_graph : dict
    - _domain_deps : dict
    - _table_to_domain : dict
    --
    + __init__(ctx: EngineContext)
    - _build_index()
    + reachable_domains(core_domains) : set
    + find_join_path(src, dst, allowed_domains) : list
    + resolve(ref_str) : ResolvedField
    + resolve_many(refs) : dict
    + get_field_catalog() : dict
  }

  class StorageRouter <<frozen dataclass>> {
    + storage_cfg : dict
    + repo_root : Optional[Path]
    --
    + parse_table_ref(table_ref) : tuple
    + resolve(table_ref) : str
    + bronze_path(logical_table) : str
    + silver_path(logical_rel) : str
  }

  class Aggregator {
    + {static} aggregate(ctx: EngineContext, df, group_by, aggs) : Any
    + {static} infer_aggregations(model_name, cols, registry) : dict
    + {static} default_aggregation(column_name) : str
  }

  class JoinPlanner {
    + ctx : EngineContext
    --
    + build_column_index(model_name) : dict
    + find_materialized_view(model, required_cols) : str
    + plan_auto_joins(model, base_table, missing_cols, filters) : dict
    + execute_auto_joins(model, plan, cols, filters, group_by, aggs)
    - _build_where_clause(filters, base, available_cols) : str
    - _parse_join_condition(condition) : tuple
  }

  FieldResolver ..> EngineContext : reads config from
  JoinPlanner ..> FieldResolver : uses join graph
  EngineContext *-- StorageRouter
  EngineContext *-- FieldResolver
  EngineContext *-- JoinPlanner
}

