@startuml "de_Funk Full Vision — Target Architecture"

skinparam classFontName "Courier New"
skinparam classFontSize 10
skinparam packageFontSize 12
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam style strictuml

title de_Funk Full Vision — Target Architecture\nEngine/Session pattern. Typed data classes. Three paths.

note as ThreePaths
  | Path | Reads | Writes | Config Needed |
  | **Ingestion** | External APIs | Raw + Bronze | ProviderConfig + EndpointConfig |
  | **Build** | Bronze + Silver | Silver | DomainModelConfig + SourceConfig |
  | **Query** | Silver (+ Bronze) | nothing | DomainModelConfig (tables, graph, measures) |
end note

' ══════════════════════════════════════════════════════════
' DOMAIN DATA CLASSES
' ══════════════════════════════════════════════════════════
package "Domain Data Classes" #FFCC66 {

  class SchemaField <<dataclass>> {
    + name : str
    + type : str
    + nullable : bool
    + description : str
    + derived : Optional[str]
    + fk : Optional[str]
    + format : Optional[str]
  }

  class EdgeSpec <<dataclass>> {
    + name : str
    + from_table : str
    + to_table : str
    + join_keys : list[str]
    + cardinality : str
    + target_domain : Optional[str]
    + optional : bool
  }

  class MeasureDef <<dataclass>> {
    + name : str
    + aggregation : str
    + field : str | dict
    + label : str
    + format : Optional[str]
    + options : dict
  }

  class AliasSpec <<dataclass>> {
    + target_column : str
    + expression : str
  }

  class EnrichSpec <<dataclass>> {
    + from_table : str
    + join : list[str]
    + columns : list[str]
  }

  class TableConfig <<dataclass>> {
    + table : str
    + table_type : str
    + schema : list[SchemaField]
    + primary_key : list[str]
    + unique_key : list[str]
    + partition_by : list[str]
    + measures : list[MeasureDef]
    + enrich : list[EnrichSpec]
    + extends : Optional[str]
  }

  class SourceConfig <<dataclass>> {
    + source : str
    + maps_to : str
    + from_ref : str
    + aliases : list[AliasSpec]
    + domain_source : Optional[str]
    + filter : list[str]
    + extends : Optional[str]
  }

  class GraphSpec <<dataclass>> {
    + edges : list[EdgeSpec]
    + paths : dict[str, Any]
  }

  class BuildSpec <<dataclass>> {
    + sort_by : list[str]
    + optimize : bool
    + partitions : list[str]
    + phases : dict[str, PhaseSpec]
  }

  class MeasuresSpec <<dataclass>> {
    + simple : list[MeasureDef]
    + computed : list[MeasureDef]
  }

  class DomainModelConfig <<dataclass>> {
    + model : str
    + version : str
    + description : str
    + extends : list[str]
    + depends_on : list[str]
    + status : str
    + storage : ModelStorageSpec
    + graph : GraphSpec
    + build : BuildSpec
    + measures : MeasuresSpec
    + metadata : dict
    --
    + tables : dict[str, TableConfig]
    + sources : dict[str, SourceConfig]
    + views : dict[str, Any]
  }

  DomainModelConfig *-- GraphSpec
  DomainModelConfig *-- BuildSpec
  DomainModelConfig *-- MeasuresSpec
  DomainModelConfig *-- TableConfig
  DomainModelConfig *-- SourceConfig
  TableConfig *-- SchemaField
  TableConfig *-- MeasureDef
  TableConfig *-- EnrichSpec
  SourceConfig *-- AliasSpec
  GraphSpec *-- EdgeSpec
  MeasuresSpec *-- MeasureDef
}

' ══════════════════════════════════════════════════════════
' PROVIDER DATA CLASSES
' ══════════════════════════════════════════════════════════
package "Provider Data Classes" #CC9966 {

  class EndpointSchemaField <<dataclass>> {
    + name : str
    + type : str
    + source_field : str
    + nullable : bool
    + description : str
    + transform : Optional[str]
    + coerce : Optional[str]
    + default : Optional[Any]
  }

  class EndpointConfig <<dataclass>> {
    + endpoint_id : str
    + provider : str
    + method : str
    + endpoint_pattern : str
    + format : str
    + default_query : dict
    + required_params : list[str]
    + pagination_type : str
    + bulk_download : bool
    + json_structure : str
    + schema : list[EndpointSchemaField]
    + bronze : Optional[str]
    + partitions : list[str]
    + write_strategy : str
    + key_columns : list[str]
    + date_column : Optional[str]
    + domain : str
    + status : str
  }

  class ProviderConfig <<dataclass>> {
    + provider_id : str
    + provider : str
    + api_type : str
    + base_url : str
    + auth_model : str
    + env_api_key : str
    + rate_limit_per_sec : float
    + default_headers : dict
    + provider_settings : dict
    + endpoints : list[str]
    + models : list[str]
    + category : str
    + status : str
  }

  EndpointConfig *-- EndpointSchemaField
}

' ══════════════════════════════════════════════════════════
' INFRASTRUCTURE DATA CLASSES
' ══════════════════════════════════════════════════════════
package "Infrastructure Data Classes" #E6E6E6 {

  class RootsConfig <<dataclass>> {
    + raw : str
    + bronze : str
    + silver : str
  }

  class ApiLimits <<dataclass>> {
    + duckdb_memory_limit : str
    + max_sql_rows : int
    + max_dimension_values : int
    + max_response_mb : float
  }

  class StorageConfig <<dataclass>> {
    + roots : RootsConfig
    + api : ApiLimits
    + default_format : str
    + domain_roots : dict[str, str]
    + tables : dict[str, TablePath]
  }

  class ConnectionConfig <<dataclass>> {
    + type : str
    + spark : Optional[SparkConfig]
    + duckdb : Optional[DuckDBConfig]
  }

  class RunConfig <<dataclass>> {
    + defaults : dict
    + providers : dict[str, dict]
    + silver_models : list[str]
    + cluster : ClusterConfig
    + retry : RetryConfig
    + profiles : dict[str, dict]
  }

  StorageConfig *-- RootsConfig
  StorageConfig *-- ApiLimits
}

' ══════════════════════════════════════════════════════════
' ENGINE (long-lived — connection + read/write mechanics)
' ══════════════════════════════════════════════════════════
package "Engine" #80E0D0 {

  class Engine {
    + conn : DataConnection
    + backend : str
    + storage : StorageConfig
    - _ops : DataOps
    - _sql : SqlOps
    --
    + select(df, columns) : Any
    + filter(df, filters) : Any
    + derive(df, col, expr) : Any
    + join(left, right, on, how) : Any
    + union(dfs) : Any
    + dedup(df, subset) : Any
    + read(path) : Any
    + write(df, path, format, mode) : Any
    + count(df) : int
    + to_pandas(df) : DataFrame
    + execute_sql(sql) : Any
    + scan(path) : str
    --
    + ingest_session(**kwargs) : IngestSession
    + build_session(**kwargs) : BuildSession
    + query_session(**kwargs) : QuerySession
    --
    + {static} for_spark(spark, storage) : Engine
    + {static} for_duckdb(duckdb_path, storage) : Engine
  }

  interface DataOps <<interface>> {
    + select(df, columns) : Any
    + filter(df, filters) : Any
    + derive(df, col, expr) : Any
    + join(left, right, on, how) : Any
    + union(dfs) : Any
    + dedup(df, subset) : Any
    + read(path) : Any
    + write(df, path, format, mode) : Any
    + count(df) : int
    + to_pandas(df) : DataFrame
  }

  interface SqlOps <<interface>> {
    + execute_sql(sql, max_rows) : list
    + scan(path) : str
    + build_from(tables, resolver) : str
    + build_where(filters) : str
    + distinct_values(resolved) : list
  }

  class DuckDBOps {
    - _conn : duckdb.Connection
    - _scan_cache : dict
  }

  class SparkOps {
    - _spark_session
  }

  class DuckDBSql {
    - _conn : duckdb.Connection
  }

  class SparkSql {
    - _spark_session
  }

  Engine *-- DataOps : _ops
  Engine *-- SqlOps : _sql
  DataOps <|.. DuckDBOps
  DataOps <|.. SparkOps
  SqlOps <|.. DuckDBSql
  SqlOps <|.. SparkSql
  Engine *-- StorageConfig
}

' ══════════════════════════════════════════════════════════
' SESSIONS (short-lived — scoped to a path)
' ══════════════════════════════════════════════════════════
package "Sessions" #80E0D0 {

  abstract class Session <<abstract>> {
    + engine : Engine
    --
    + {abstract} close()
  }

  class IngestSession {
    + engine : Engine
    + providers : dict[str, ProviderConfig]
    + endpoints : dict[str, EndpointConfig]
    + run : RunConfig
    --
    + get_provider(provider_id) : ProviderConfig
    + get_endpoint(provider_id, endpoint_id) : EndpointConfig
    + raw_path(provider, endpoint) : str
    + bronze_path(provider, endpoint) : str
  }

  class BuildSession {
    + engine : Engine
    + models : dict[str, DomainModelConfig]
    + loader : DomainConfigLoader
    --
    + get_model(model_name) : DomainModelConfig
    + get_dependencies(model_name) : list[str]
    + build(model_name) : BuildResult
    + build_all() : list[BuildResult]
    + silver_path(domain, model) : str
    + bronze_path(provider, endpoint) : str
  }

  class QuerySession {
    + engine : Engine
    + models : dict[str, DomainModelConfig]
    + resolver : FieldResolver
    + storage_router : StorageRouter
    --
    + resolve(ref_str) : ResolvedField
    + find_join_path(src, dst) : list
    + distinct_values(resolved) : list
    + build_from(tables, allowed_domains) : str
    + build_where(filters) : str
  }

  Session <|-- IngestSession
  Session <|-- BuildSession
  Session <|-- QuerySession

  Engine ..> IngestSession : creates
  Engine ..> BuildSession : creates
  Engine ..> QuerySession : creates

  IngestSession *-- ProviderConfig
  IngestSession *-- EndpointConfig
  IngestSession *-- RunConfig

  BuildSession *-- DomainModelConfig

  QuerySession *-- DomainModelConfig
  QuerySession *-- FieldResolver
  QuerySession *-- StorageRouter
}

' ══════════════════════════════════════════════════════════
' FIELD RESOLUTION
' ══════════════════════════════════════════════════════════
package "Field Resolution" #80E0D0 {

  class FieldRef <<dataclass>> {
    + domain : str
    + field : str
    + raw : str
  }

  class ResolvedField <<dataclass>> {
    + ref : FieldRef
    + table_name : str
    + column : str
    + silver_path : Path
    + format_code : Optional[str]
    + domain : str <<property>>
  }

  class FieldResolver {
    - _index : dict
    - _join_graph : dict
    - _domain_deps : dict
    --
    + __init__(models: dict[str, DomainModelConfig])
    + resolve(ref_str) : ResolvedField
    + resolve_many(refs) : dict
    + find_join_path(src, dst, allowed_domains) : list
    + reachable_domains(core_domains) : set
    + get_field_catalog() : dict
  }

  class StorageRouter <<dataclass>> {
    + roots : RootsConfig
    + domain_roots : dict[str, str]
    + tables : dict[str, TablePath]
    --
    + resolve(table_ref) : str
    + raw_path(provider, endpoint) : str
    + bronze_path(provider, endpoint) : str
    + silver_path(domain, model) : str
  }

  FieldResolver ..> DomainModelConfig : reads edges + schema
}

' ══════════════════════════════════════════════════════════
' CONFIG LOADING
' ══════════════════════════════════════════════════════════
package "Config Loading" #FFCC66 {

  class DomainConfigLoader {
    - domains_dir : Path
    - _parse_cache : dict
    --
    + load_model_config(model_name) : DomainModelConfig
    + load_all() : dict[str, DomainModelConfig]
  }

  class config_translator <<module>> {
    + {static} translate_domain_config(config) : dict
  }

  class extends_resolver <<module>> {
    + {static} parse_front_matter(file_path) : dict
    + {static} deep_merge(base, override) : dict
    + {static} resolve_extends_reference(ref, dir, cache) : dict
  }

  DomainConfigLoader ..> config_translator
  DomainConfigLoader ..> extends_resolver
}

' ══════════════════════════════════════════════════════════
' CONNECTION HIERARCHY
' ══════════════════════════════════════════════════════════
package "Connections" #E6E6E6 {

  interface DataConnection <<interface>> {
    + read_table(path, format) : Any
    + apply_filters(df, filters) : Any
    + to_pandas(df) : DataFrame
    + count(df) : int
    + cache(df) : Any
    + stop()
  }

  class DuckDBConnection {
    + conn : duckdb.Connection
    + db_path : str
    + delta_enabled : bool
    --
    + read_table(path, format, version, timestamp)
    + execute_sql(query) : Any
    + write_delta_table(df, path, mode, partition_by)
    + apply_filters(df, filters) : Any
    + to_pandas(df) : DataFrame
    + count(df) : int
  }

  class SparkConnection {
    + spark_session
    --
    + read_table(path, format, version, timestamp)
    + write_delta_table(df, path, mode, partition_by)
    + merge_delta_table(source_df, target_path, condition)
    + apply_filters(df, filters) : Any
    + to_pandas(df) : DataFrame
    + count(df) : int
  }

  DataConnection <|.. DuckDBConnection
  DataConnection <|.. SparkConnection
  Engine *-- DataConnection : conn
}

' ══════════════════════════════════════════════════════════
' BUILD PATH
' ══════════════════════════════════════════════════════════
package "Build Path" #FF9933 {

  class BaseModel <<abstract>> {
    + session : BuildSession
    + config : DomainModelConfig
    - _dims : dict
    - _facts : dict
    --
    + build() : tuple[dict, dict]
    + before_build()
    + after_build(dims, facts)
    + custom_node_loading(node_id, config) : Optional[DF]
    + write_tables(output_root, format, mode)
    + get_table(name) : Any
    + has_table(name) : bool
    + list_tables() : list[str]
  }

  class DomainModel {
    .. default for all domains ..
    + custom_node_loading(node_id, config)
    .. handles: seed, union, distinct, window, unpivot ..
  }

  class BaseModelBuilder <<abstract>> {
    + model_name : str
    + depends_on : list[str]
    + session : BuildSession
    --
    + {abstract} get_model_class() : Type
    + validate()
    + pre_build()
    + post_build(result)
    + build() : BuildResult
  }

  class DomainBuilderFactory {
    --
    + {static} create_builders(domains_dir) : dict
  }

  class BuildResult <<dataclass>> {
    + model_name : str
    + success : bool
    + rows_written : int
    + duration_seconds : float
    + error : Optional[str]
  }

  note as BuildHooks
    Known build hooks (registered as plugins):
    - temporal: generate dim_calendar programmatically
    - corporate.entity: after_build CIK enrichment
    - securities.stocks: post_build technical indicators
    - securities.forecast: custom ML training build
  end note

  BaseModel <|-- DomainModel
  BaseModel ..> BuildSession : uses session
  BaseModelBuilder ..> BuildSession : uses session
  BaseModelBuilder ..> BaseModel : creates + builds
}

' ══════════════════════════════════════════════════════════
' HANDLER HIERARCHY (API)
' ══════════════════════════════════════════════════════════
package "Handler Hierarchy (API)" #B3D9FF {

  abstract class ExhibitHandler <<abstract>> {
    + handles : set[str]
    + session : QuerySession
    --
    + {abstract} execute(payload: dict, resolver: Any) : Any
  }

  class HandlerRegistry {
    - _handlers : dict
    + session : QuerySession
    --
    + register(handler)
    + get(type_str) : ExhibitHandler
    + supported_types : set <<property>>
  }

  class GraphicalHandler {
    + handles : {line, bar, scatter, area, pie, heatmap}
    --
    + execute(payload, resolver) : GraphicalResponse
  }

  class PivotHandler {
    + handles : {pivot, great_table, gt}
    --
    + execute(payload, resolver) : GreatTablesResponse
  }

  class MetricsHandler {
    + handles : {cards.metric, kpi}
    --
    + execute(payload, resolver) : MetricResponse
  }

  class BoxHandler {
    + handles : {box, ohlcv, candlestick}
    --
    + execute(payload, resolver) : dict
  }

  class TableDataHandler {
    + handles : {table.data}
    --
    + execute(payload, resolver) : TableResponse
  }

  ExhibitHandler <|-- GraphicalHandler
  ExhibitHandler <|-- PivotHandler
  ExhibitHandler <|-- MetricsHandler
  ExhibitHandler <|-- BoxHandler
  ExhibitHandler <|-- TableDataHandler

  ExhibitHandler ..> QuerySession : uses session
}

' ══════════════════════════════════════════════════════════
' INGESTION PATH
' ══════════════════════════════════════════════════════════
package "Ingestion Path" #CC9966 {

  abstract class BaseProvider <<abstract>> {
    + session : IngestSession
    --
    + {abstract} list_work_items(**kwargs) : list
    + {abstract} fetch(work_item, **kwargs) : Generator
    + {abstract} normalize(records, work_item) : DF
    + {abstract} get_table_name(work_item) : str
  }

  class IngestorEngine {
    + session : IngestSession
    + raw_sink : RawSink
    + bronze_sink : BronzeSink
    --
    + run(provider_id, work_items, **kwargs)
  }

  class RawSink {
    + raw_root : Path
    --
    + write(data, provider, endpoint, partition) : Path
    + exists(provider, endpoint, partition) : bool
    + read(provider, endpoint, partition) : Any
  }

  class BronzeSink {
    + engine : Engine
    --
    + write_if_missing(table, partitions, df) : bool
    + upsert(df, table, merge_keys, partitions) : str
    + rebuild_from_raw(provider, endpoint) : str
  }

  class HttpClient {
    + base_url : str
    - _token_bucket : TokenBucket
    - _circuit_breaker : CircuitBreaker
    --
    + get(path, params) : Response
  }

  class TokenBucket {
    + rate : float
    + capacity : int
    --
    + acquire(timeout) : bool
  }

  class CircuitBreaker {
    - _state : str
    --
    + call(fn, *args, **kwargs) : Any
    + reset()
  }

  class ApiKeyPool {
    - _keys : list
    --
    + next_key() : str
    + mark_exhausted(key)
  }

  BaseProvider ..> IngestSession : uses session
  IngestorEngine *-- RawSink
  IngestorEngine *-- BronzeSink
  RawSink ..> BronzeSink : feeds
  HttpClient *-- TokenBucket
  HttpClient *-- CircuitBreaker
}

' ══════════════════════════════════════════════════════════
' ORCHESTRATION
' ══════════════════════════════════════════════════════════
package "Orchestration" #CC99FF {

  class PipelineScheduler {
    --
    + add_job(func, trigger, **trigger_args)
    + start()
    + shutdown()
  }

  class DependencyGraph {
    --
    + build()
    + topological_sort() : list[str]
    + filter_buildable(model_names) : list[str]
  }
}

' ══════════════════════════════════════════════════════════
' APP CONFIGURATION
' ══════════════════════════════════════════════════════════
package "App Configuration" #E6E6E6 {

  class ConfigLoader {
    --
    + load(connection_type, log_level) : AppConfig
  }

  class AppConfig <<dataclass>> {
    + repo_root : Path
    + connection : ConnectionConfig
    + storage : StorageConfig
    + apis : dict[str, APIConfig]
  }

  class ConnectionFactory {
    + {static} create(connection_type, **kwargs) : DataConnection
  }

  ConfigLoader ..> AppConfig : produces
  AppConfig ..> Engine : creates
}

' ══════════════════════════════════════════════════════════
' PLUGIN SYSTEM
' ══════════════════════════════════════════════════════════
package "Plugin System" #B3FFB3 {
  class BuildPluginRegistry {
    --
    + {static} register(hook_type, model_name, fn)
    + {static} get(hook_type, model_name) : list
    + {static} discover(plugins_dir)
  }
}

' ══════════════════════════════════════════════════════════
' KEY RELATIONSHIPS
' ══════════════════════════════════════════════════════════
DomainBuilderFactory ..> DomainConfigLoader : loads configs
PipelineScheduler ..> DependencyGraph : build order
BuildSession ..> DomainConfigLoader : loads models

' ══════════════════════════════════════════════════════════
' MEASURES NOTE
' ══════════════════════════════════════════════════════════
note as MeasureNote
  Measures: defined in DomainModelConfig.measures (YAML).
  Translated to SQL by build_measure_sql() function.
  No class hierarchy — YAML is the definition.
  Used by: PivotHandler, MetricsHandler.
end note

' ══════════════════════════════════════════════════════════
' STORAGE NOTE
' ══════════════════════════════════════════════════════════
note as StorageNote
  | Layer | Mount | Path |
  | Raw | HDD/NAS | /mnt/disk/storage/raw/{provider}/{endpoint}/ |
  | Bronze | SSD | /shared/storage/bronze/{provider}/{endpoint}/ |
  | Silver | SSD | /shared/storage/silver/{domain}/{model}/ |
end note

