        <!-- Methods Section 7: Measure Calculations -->
        <mxCell id="basemodel-measures" value="&lt;b&gt;## MEASURE CALCULATIONS (4 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ calculate_measure(measure_name, entity_column=None, filters=None, limit=None, **kwargs) → QueryResult|DataFrame&lt;br&gt;  # UNIFIED METHOD: Calculate any measure (YAML or Python)&lt;br&gt;  # Works with all measure types and backends&lt;br&gt;&lt;br&gt;+ calculate_measure_by_entity(measure_name, entity_column, limit=None) → DataFrame&lt;br&gt;  # Calculate measure aggregated by entity (Spark only)&lt;br&gt;  # Reads from YAML config and calculates from facts&lt;br&gt;&lt;br&gt;- _is_python_measure(measure_name) → bool&lt;br&gt;  # Check if measure is defined as Python measure&lt;br&gt;&lt;br&gt;- _execute_python_measure(measure_name, **kwargs) → DataFrame&lt;br&gt;  # Execute Python measure function" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="basemodel-class">
