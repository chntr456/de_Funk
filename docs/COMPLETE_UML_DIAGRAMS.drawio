        <!-- 2. Loop through tickers -->
        <mxCell id="loop-box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9e9e9e;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="320" width="900" height="900" as="geometry" />
        </mxCell>
        <mxCell id="loop-label" value="loop [for each ticker in tickers]" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="430" y="295" width="250" height="20" as="geometry" />
