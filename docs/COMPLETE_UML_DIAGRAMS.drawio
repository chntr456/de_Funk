          <mxGeometry x="1020" y="645" width="400" height="35" as="geometry" />
        </mxCell>
        <mxCell id="bronze-sink-text" value="&lt;b&gt;Class: BronzeSink&lt;/b&gt;&lt;br&gt;&lt;i&gt;datapipelines/ingestors/bronze_sink.py&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;# ATTRIBUTES&lt;/b&gt;&lt;br&gt;+ storage_router: StorageRouter&lt;br&gt;+ format: str = 'parquet'&lt;br&gt;&lt;br&gt;&lt;b&gt;# METHODS&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ write(df: DataFrame, table_name: str, partition_cols: List[str], mode='append')&lt;br&gt;  # Write DataFrame to Bronze layer as Parquet&lt;br&gt;  # Path: storage/bronze/{table_name}/{partitions}/&lt;br&gt;  # Supports partitioning by: asset_type, year, month&lt;br&gt;&lt;br&gt;&lt;b&gt;Partition Strategy (v2.0):&lt;/b&gt;&lt;br&gt;• securities_reference: partition_by=['snapshot_dt', 'asset_type']&lt;br&gt;• securities_prices_daily: partition_by=['trade_date', 'asset_type']&lt;br&gt;&lt;br&gt;Example paths:&lt;br&gt;storage/bronze/securities_reference/snapshot_dt=2024-11-21/asset_type=stocks/&lt;br&gt;storage/bronze/securities_prices_daily/trade_date=2024-11-21/asset_type=stocks/" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="1020" y="690" width="710" height="195" as="geometry" />
        </mxCell>

        <!-- Data Flow Diagram -->
        <mxCell id="flow-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="80" y="950" width="1670" height="280" as="geometry" />
        </mxCell>
        <mxCell id="flow-title" value="📊 Data Flow: API -> Bronze Layer" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#e65100" vertex="1" parent="1">
          <mxGeometry x="100" y="965" width="500" height="35" as="geometry" />
        </mxCell>
        <mxCell id="flow-text" value="┌──────────────────┐     ┌──────────────────┐     ┌──────────────────┐     ┌──────────────────┐     ┌──────────────────┐&lt;br&gt;│ Alpha Vantage API│────▶│ HttpClient       │────▶│ Facet.normalize()│────▶│ Facet.postprocess│────▶│ Facet.validate() │&lt;br&gt;│                  │     │ (Rate Limiting)  │     │ (JSON -> DF)      │     │ (Transform)      │     │ (Quality Check)  │&lt;br&gt;└──────────────────┘     └──────────────────┘     └──────────────────┘     └──────────────────┘     └──────────────────┘&lt;br&gt;                                                                                                              │&lt;br&gt;                                                                                                              ▼&lt;br&gt;                                                                                                   ┌──────────────────┐&lt;br&gt;                                                                                                   │ BronzeSink.write()│&lt;br&gt;                                                                                                   │ Parquet + Partition│&lt;br&gt;                                                                                                   └──────────────────┘&lt;br&gt;                                                                                                              │&lt;br&gt;                                                                                                              ▼&lt;br&gt;                                                                         storage/bronze/securities_*/..." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=8;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="100" y="1010" width="1630" height="205" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- TAB 3: Universal Session -->
  <diagram id="universal-session" name="3. Universal Session">
    <mxGraphModel dx="2400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title-session" value="Universal Session - Cross-Model Query Engine" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="1800" height="50" as="geometry" />
        </mxCell>

        <!-- UniversalSession Class -->
        <mxCell id="session-class" value="&lt;b&gt;UniversalSession&lt;/b&gt;&lt;br&gt;&lt;i&gt;models/api/session.py (1,122+ lines)&lt;/i&gt;" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=70;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="1100" height="1600" as="geometry" />
        </mxCell>

        <!-- Session Attributes -->
        <mxCell id="session-attrs" value="&lt;b&gt;# ATTRIBUTES&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ backend: str  # 'spark' or 'duckdb'&lt;br&gt;+ connection: Any  # Backend connection&lt;br&gt;+ config: Dict[str, Any]&lt;br&gt;+ model_registry: ModelRegistry&lt;br&gt;+ filter_engine: FilterEngine" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=10;" vertex="1" parent="session-class">
          <mxGeometry y="70" width="1100" height="110" as="geometry" />
        </mxCell>

        <mxCell id="session-line1" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;strokeColor=#2e7d32;" vertex="1" parent="session-class">
          <mxGeometry y="180" width="1100" height="8" as="geometry" />
        </mxCell>

        <!-- Session Methods -->
        <mxCell id="session-init" value="&lt;b&gt;## INITIALIZATION (2 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ __init__(backend, config)&lt;br&gt;+ @property backend() -> str" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="session-class">
          <mxGeometry y="188" width="1100" height="70" as="geometry" />
        </mxCell>

        <mxCell id="session-model-mgmt" value="&lt;b&gt;## MODEL MANAGEMENT (4 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ load_model(model_name: str) -> BaseModel&lt;br&gt;  # Load and initialize model from registry&lt;br&gt;&lt;br&gt;+ get_model_instance(model_name: str) -> BaseModel&lt;br&gt;  # Get cached model instance&lt;br&gt;&lt;br&gt;+ list_models() -> List[str]&lt;br&gt;  # List all available models&lt;br&gt;&lt;br&gt;+ get_model_metadata(model_name: str) -> Dict[str, Any]&lt;br&gt;  # Get model metadata (version, dependencies, etc.)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="session-class">
          <mxGeometry y="258" width="1100" height="150" as="geometry" />
        </mxCell>

        <mxCell id="session-table-ops" value="&lt;b&gt;## TABLE OPERATIONS (5 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ get_table(model_name, table_name, filters=None, columns=None, enrich_with=None) -> DataFrame&lt;br&gt;  # Get table from model with optional filters and enrichment&lt;br&gt;&lt;br&gt;+ get_dimension_df(model_name: str, dim_id: str) -> DataFrame&lt;br&gt;  # Get dimension table&lt;br&gt;&lt;br&gt;+ get_fact_df(model_name: str, fact_id: str) -> DataFrame&lt;br&gt;  # Get fact table&lt;br&gt;&lt;br&gt;+ list_tables(model_name: str) -> Dict[str, List[str]]&lt;br&gt;  # List tables in model {'dimensions': [...], 'facts': [...]}&lt;br&gt;&lt;br&gt;+ should_apply_cross_model_filter(filter_config, model_name, table_name) -> bool&lt;br&gt;  # Determine if filter applies across models" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="session-class">
          <mxGeometry y="408" width="1100" height="180" as="geometry" />
        </mxCell>

        <mxCell id="session-joins" value="&lt;b&gt;## AUTO-JOIN PLANNING (5 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;- _plan_auto_joins(model_name, table_name, enrich_with, columns) -> Dict&lt;br&gt;  # Plan join graph for enrichment&lt;br&gt;&lt;br&gt;- _execute_auto_joins(base_df, join_plan, model) -> DataFrame&lt;br&gt;  # Execute planned joins&lt;br&gt;&lt;br&gt;- _build_column_index(model_name: str) -> Dict[str, List[str]]&lt;br&gt;  # Build index of columns -> tables&lt;br&gt;&lt;br&gt;- _parse_join_condition(condition: str) -> Tuple[str, str]&lt;br&gt;  # Parse join condition 'left.col = right.col'&lt;br&gt;&lt;br&gt;- _find_materialized_view(model, model_name, table_name, enrich_with) -> Optional[str]&lt;br&gt;  # Find pre-built materialized view for query" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="session-class">
          <mxGeometry y="588" width="1100" height="190" as="geometry" />
        </mxCell>

        <mxCell id="session-filters" value="&lt;b&gt;## FILTER MANAGEMENT (1 method)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ get_filter_column_mappings(model_name: str, table_name: str) -> Dict[str, str]&lt;br&gt;  # Get filter column mappings for table" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="session-class">
          <mxGeometry y="778" width="1100" height="70" as="geometry" />
        </mxCell>

        <mxCell id="session-aggregations" value="&lt;b&gt;## AGGREGATION (5 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;- _aggregate_data(df, measure_cols, group_by, aggregations) -> DataFrame&lt;br&gt;  # Backend-agnostic aggregation&lt;br&gt;&lt;br&gt;- _infer_aggregations(model_name, measure_cols) -> Dict[str, str]&lt;br&gt;  # Infer aggregation type from column name/type&lt;br&gt;&lt;br&gt;- _default_aggregation(column_name: str) -> str&lt;br&gt;  # Determine default aggregation (sum/avg/count)&lt;br&gt;&lt;br&gt;- _aggregate_spark(df, measure_cols, group_by, aggregations) -> DataFrame&lt;br&gt;  # Spark-specific aggregation&lt;br&gt;&lt;br&gt;- _aggregate_duckdb(df, measure_cols, group_by, aggregations) -> DataFrame&lt;br&gt;  # DuckDB-specific aggregation" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="session-class">
          <mxGeometry y="848" width="1100" height="180" as="geometry" />
        </mxCell>

        <mxCell id="session-backend-helpers" value="&lt;b&gt;## BACKEND HELPERS (2 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;- _select_columns(df: Any, columns: List[str]) -> Any&lt;br&gt;  # Backend-agnostic column selection&lt;br&gt;&lt;br&gt;- _get_table_from_view_or_build(model, model_name, table_name) -> DataFrame&lt;br&gt;  # Get table from materialized view or build fresh" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="session-class">
          <mxGeometry y="1028" width="1100" height="100" as="geometry" />
        </mxCell>

        <mxCell id="session-summary" value="&lt;b&gt;TOTAL: 29+ PUBLIC/PRIVATE METHODS&lt;/b&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=11;fontStyle=1;fillColor=#fff3e0;" vertex="1" parent="session-class">
          <mxGeometry y="1128" width="1100" height="30" as="geometry" />
        </mxCell>

        <!-- Key Features Box -->
        <mxCell id="session-features-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;" vertex="1" parent="1">
          <mxGeometry x="1250" y="100" width="700" height="450" as="geometry" />
        </mxCell>
        <mxCell id="session-features-title" value="✨ Key Features" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#1976d2" vertex="1" parent="1">
          <mxGeometry x="1270" y="115" width="400" height="35" as="geometry" />
        </mxCell>
        <mxCell id="session-features-text" value="&lt;b&gt;1. Backend Abstraction&lt;/b&gt;&lt;br&gt;   • Unified API for Spark and DuckDB&lt;br&gt;   • Automatic backend detection&lt;br&gt;   • Backend-specific optimizations&lt;br&gt;&lt;br&gt;&lt;b&gt;2. Cross-Model Access&lt;/b&gt;&lt;br&gt;   • Query tables from any loaded model&lt;br&gt;   • Automatic dependency resolution&lt;br&gt;   • Cross-model filter propagation&lt;br&gt;&lt;br&gt;&lt;b&gt;3. Auto-Join Planning&lt;/b&gt;&lt;br&gt;   • Graph-based join discovery&lt;br&gt;   • Materialized view optimization&lt;br&gt;   • Column index for fast lookup&lt;br&gt;&lt;br&gt;&lt;b&gt;4. Dynamic Enrichment&lt;/b&gt;&lt;br&gt;   • enrich_with parameter for auto-joins&lt;br&gt;   • Example: get_table('stocks', 'fact_prices',&lt;br&gt;     enrich_with=['company.sector', 'company.name'])&lt;br&gt;&lt;br&gt;&lt;b&gt;5. Filter Management&lt;/b&gt;&lt;br&gt;   • Column mapping for flexible filtering&lt;br&gt;   • Cross-model filter application&lt;br&gt;   • Backend-agnostic filter expressions&lt;br&gt;&lt;br&gt;&lt;b&gt;6. Aggregation Engine&lt;/b&gt;&lt;br&gt;   • Inferred aggregations by column type&lt;br&gt;   • Backend-specific implementations&lt;br&gt;   • Support for complex measure calculations" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="1270" y="160" width="660" height="375" as="geometry" />
        </mxCell>

        <!-- Example Usage Box -->
        <mxCell id="session-example-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="1250" y="580" width="700" height="400" as="geometry" />
        </mxCell>
        <mxCell id="session-example-title" value="💡 Example Usage" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#e65100" vertex="1" parent="1">
          <mxGeometry x="1270" y="595" width="400" height="35" as="geometry" />
        </mxCell>
        <mxCell id="session-example-text" value="# Initialize session&lt;br&gt;session = UniversalSession(backend='duckdb', config=config)&lt;br&gt;&lt;br&gt;# Load models&lt;br&gt;session.load_model('stocks')&lt;br&gt;session.load_model('company')&lt;br&gt;&lt;br&gt;# Get table with filters&lt;br&gt;prices = session.get_table(&lt;br&gt;    model_name='stocks',&lt;br&gt;    table_name='fact_prices',&lt;br&gt;    filters=[&lt;br&gt;        {'column': 'ticker', 'operator': 'in', 'value': ['AAPL', 'MSFT']},&lt;br&gt;        {'column': 'trade_date', 'operator': '&gt;=', 'value': '2024-01-01'}&lt;br&gt;    ]&lt;br&gt;)&lt;br&gt;&lt;br&gt;# Get table with auto-joins (cross-model enrichment)&lt;br&gt;enriched = session.get_table(&lt;br&gt;    model_name='stocks',&lt;br&gt;    table_name='dim_stock',&lt;br&gt;    enrich_with=['company.sector', 'company.name', 'company.market_cap'],&lt;br&gt;    columns=['ticker', 'close_price', 'company.sector', 'company.name']&lt;br&gt;)&lt;br&gt;# Result: Automatically joins stocks.dim_stock ← company.dim_company on company_id&lt;br&gt;&lt;br&gt;# List available models and tables&lt;br&gt;models = session.list_models()  # ['core', 'company', 'stocks', ...]&lt;br&gt;tables = session.list_tables('stocks')  # {'dimensions': [...], 'facts': [...]}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="1270" y="640" width="660" height="325" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

