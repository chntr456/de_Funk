  </diagram>

  <!-- TAB 5: Notebook Parser &amp; Manager Architecture -->
  <diagram id="notebook-parser" name="5. Notebook Parser &amp; Manager">
    <mxGraphModel dx="2400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title-parser" value="Notebook Parser &amp; Manager Architecture - Markdown -> Exhibits" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#6a1b9a;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="2000" height="50" as="geometry" />
        </mxCell>

        <!-- MarkdownNotebookParser Class -->
        <mxCell id="parser-class" value="&lt;b&gt;MarkdownNotebookParser&lt;/b&gt;&lt;br&gt;&lt;i&gt;app/notebook/parsers/markdown_parser.py (593 lines)&lt;/i&gt;" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=70;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#f3e5f5;strokeColor=#6a1b9a;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="850" height="650" as="geometry" />
        </mxCell>

        <mxCell id="parser-attrs" value="&lt;b&gt;# ATTRIBUTES&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ repo_root: Path" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=10;" vertex="1" parent="parser-class">
          <mxGeometry y="70" width="850" height="60" as="geometry" />
        </mxCell>

        <mxCell id="parser-line" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;strokeColor=#6a1b9a;" vertex="1" parent="parser-class">
          <mxGeometry y="130" width="850" height="8" as="geometry" />
        </mxCell>

        <mxCell id="parser-methods" value="&lt;b&gt;# METHODS (13 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ parse_file(notebook_path: str) -> NotebookConfig&lt;br&gt;+ parse_markdown(content: str) -> NotebookConfig&lt;br&gt;&lt;br&gt;&lt;i&gt;# Extraction (5 methods)&lt;/i&gt;&lt;br&gt;- _extract_front_matter(content) -> Optional[Dict]&lt;br&gt;- _extract_dynamic_filters(content) -> FilterCollection&lt;br&gt;- _extract_exhibits(content) -> Tuple[List[Exhibit], List[Dict]]&lt;br&gt;- _add_content_with_collapsibles(...) -> int&lt;br&gt;- _parse_exhibit(exhibit_yaml, exhibit_id) -> Exhibit&lt;br&gt;&lt;br&gt;&lt;i&gt;# Building&lt;/i&gt;&lt;br&gt;- _build_config(front_matter, filter_collection, exhibits, content_blocks) -> NotebookConfig&lt;br&gt;&lt;br&gt;&lt;b&gt;Regex Patterns:&lt;/b&gt;&lt;br&gt;• FRONT_MATTER_PATTERN: ^---\\s*\\n(.*?)\\n---\\s*\\n&lt;br&gt;• FILTER_PATTERN: \\$filters?\\$\\{\\s*\\n(.*?)\\n\\}&lt;br&gt;• EXHIBIT_PATTERN: \\$exhibits?\\$\\{\\s*\\n(.*?)\\n\\}&lt;br&gt;• DETAILS_PATTERN: &lt;details&gt;...&lt;/details&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="parser-class">
          <mxGeometry y="138" width="850" height="300" as="geometry" />
        </mxCell>

        <mxCell id="parser-flow" value="&lt;b&gt;Parse Flow:&lt;/b&gt;&lt;br&gt;1. parse_file(path) -> read file&lt;br&gt;2. _extract_front_matter() -> YAML metadata&lt;br&gt;3. _extract_dynamic_filters() -> $filter${...} blocks&lt;br&gt;4. _extract_exhibits() -> $exhibit${...} blocks&lt;br&gt;5. _build_config() -> NotebookConfig object" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;fillColor=#fff3e0;" vertex="1" parent="parser-class">
          <mxGeometry y="438" width="850" height="100" as="geometry" />
        </mxCell>

        <!-- NotebookManager Class -->
        <mxCell id="manager-class" value="&lt;b&gt;NotebookManager&lt;/b&gt;&lt;br&gt;&lt;i&gt;app/notebook/managers/notebook_manager.py (945 lines)&lt;/i&gt;" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=70;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1000" y="100" width="950" height="850" as="geometry" />
        </mxCell>

        <mxCell id="manager-attrs" value="&lt;b&gt;# ATTRIBUTES&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ notebook_config: NotebookConfig&lt;br&gt;+ repo_root: Path&lt;br&gt;+ universal_session: UniversalSession&lt;br&gt;+ model_sessions: Dict[str, Any]&lt;br&gt;+ folder_context: Optional[FolderContext]&lt;br&gt;+ filter_context: Dict[str, Any]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=10;" vertex="1" parent="manager-class">
          <mxGeometry y="70" width="950" height="130" as="geometry" />
        </mxCell>

        <mxCell id="manager-line" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;strokeColor=#1976d2;" vertex="1" parent="manager-class">
          <mxGeometry y="200" width="950" height="8" as="geometry" />
        </mxCell>

        <mxCell id="manager-methods" value="&lt;b&gt;# METHODS (19 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;i&gt;## Initialization (3 methods)&lt;/i&gt;&lt;br&gt;+ load_notebook(notebook_path) -> NotebookConfig&lt;br&gt;- _initialize_model_sessions()&lt;br&gt;+ get_model_session(model_name) -> Optional[Any]&lt;br&gt;&lt;br&gt;&lt;i&gt;## Filter Management (6 methods)&lt;/i&gt;&lt;br&gt;+ get_filter_context() -> Dict[str, Any]&lt;br&gt;+ update_filters(filter_values: Dict)&lt;br&gt;- _merge_filters_unified(folder_filters)&lt;br&gt;- _sync_session_state_to_filters()&lt;br&gt;- _create_filter_config_from_value(filter_id, value)&lt;br&gt;+ get_folder_display_name() -> str&lt;br&gt;&lt;br&gt;&lt;i&gt;## Data Retrieval (7 methods) ⭐ MAIN FUNCTIONALITY&lt;/i&gt;&lt;br&gt;+ get_exhibit_data(exhibit_id) -> Any&lt;br&gt;  # THE CORE METHOD - retrieves data for exhibits&lt;br&gt;- _find_exhibit(exhibit_id) -> Optional[Exhibit]&lt;br&gt;- _extract_required_columns(exhibit) -> Optional[List[str]]&lt;br&gt;- _determine_aggregation(exhibit) -> tuple&lt;br&gt;- _parse_source(source) -> tuple[str, str]&lt;br&gt;  # Parse 'model.table' string&lt;br&gt;- _build_filters(exhibit) -> Dict[str, Any]&lt;br&gt;  # Merge exhibit filters + context filters&lt;br&gt;- _get_weighted_aggregate_data(exhibit) -> Any&lt;br&gt;&lt;br&gt;&lt;i&gt;## Metadata (3 methods)&lt;/i&gt;&lt;br&gt;+ get_exhibit_list() -> List[Dict]&lt;br&gt;+ get_notebook_metadata() -> Dict[str, Any]&lt;br&gt;+ get_current_folder() -> Optional[Path]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="manager-class">
          <mxGeometry y="208" width="950" height="460" as="geometry" />
        </mxCell>

        <mxCell id="manager-flow" value="&lt;b&gt;Data Retrieval Flow (get_exhibit_data):&lt;/b&gt;&lt;br&gt;1. _find_exhibit(id) -> locate exhibit config&lt;br&gt;2. _parse_source('stocks.fact_prices') -> (model='stocks', table='fact_prices')&lt;br&gt;3. _build_filters(exhibit) -> merge exhibit filters + current filter context&lt;br&gt;4. universal_session.get_table(model, table, filters, enrich_with)&lt;br&gt;5. Return DataFrame to exhibit renderer" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;fillColor=#fff3e0;" vertex="1" parent="manager-class">
          <mxGeometry y="668" width="950" height="120" as="geometry" />
        </mxCell>

        <!-- FilterEngine -->
        <mxCell id="filter-engine-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="80" y="800" width="850" height="400" as="geometry" />
        </mxCell>
        <mxCell id="filter-engine-title" value="🔍 FilterEngine - Backend-Agnostic Filtering" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#2e7d32" vertex="1" parent="1">
          <mxGeometry x="100" y="815" width="600" height="35" as="geometry" />
        </mxCell>
        <mxCell id="filter-engine-text" value="&lt;b&gt;File:&lt;/b&gt; app/notebook/filters/engine.py (351 lines)&lt;br&gt;&lt;br&gt;&lt;b&gt;Methods (14 methods):&lt;/b&gt;&lt;br&gt;+ apply_filters(df, filters: List[FilterConfig], backend: str) -> DataFrame&lt;br&gt;+ apply_filter(df, filter: FilterConfig, backend: str) -> DataFrame&lt;br&gt;- _apply_date_range_filter(df, filter, backend) -> DataFrame&lt;br&gt;- _apply_multi_select_filter(df, filter, backend) -> DataFrame&lt;br&gt;- _apply_single_select_filter(df, filter, backend) -> DataFrame&lt;br&gt;- _apply_number_filter(df, filter, backend) -> DataFrame&lt;br&gt;- _apply_text_filter(df, filter, backend) -> DataFrame&lt;br&gt;- _apply_boolean_filter(df, filter, backend) -> DataFrame&lt;br&gt;- _apply_operator_filter(df, filter, backend) -> DataFrame&lt;br&gt;+ get_unique_values(df, column, backend, limit=1000) -> List[Any]&lt;br&gt;+ get_min_max(df, column, backend) -> Tuple[Any, Any]&lt;br&gt;+ apply_dynamic_time_filter(df, filter, backend) -> DataFrame&lt;br&gt;&lt;br&gt;&lt;b&gt;Supported Filter Types:&lt;/b&gt;&lt;br&gt;• date_range - Date range with start/end&lt;br&gt;• multi_select - Multiple value selection (ticker IN [...]&lt;br&gt;• single_select - Single value dropdown&lt;br&gt;• number - Numeric with operators (&gt;, &lt;, =, etc.)&lt;br&gt;• text - Text matching (contains, equals, startswith)&lt;br&gt;• boolean - True/False&lt;br&gt;• slider - Numeric range slider&lt;br&gt;• dynamic_time - Relative date ranges (last_7_days, last_30_days, etc.)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="100" y="860" width="810" height="325" as="geometry" />
        </mxCell>

        <!-- Integration Flow -->
        <mxCell id="integration-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="1000" y="1000" width="950" height="200" as="geometry" />
        </mxCell>
        <mxCell id="integration-title" value="🔗 Integration: Parser -> Manager -> Session -> Model" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#e65100" vertex="1" parent="1">
          <mxGeometry x="1020" y="1015" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="integration-text" value="MarkdownNotebookParser.parse_file('notebook.md')&lt;br&gt;   ↓&lt;br&gt;NotebookConfig (front_matter + filters + exhibits)&lt;br&gt;   ↓&lt;br&gt;NotebookManager(config, session, folder_context)&lt;br&gt;   ↓&lt;br&gt;manager.get_exhibit_data('exhibit_1')&lt;br&gt;   ↓&lt;br&gt;universal_session.get_table('stocks', 'fact_prices', filters=[...], enrich_with=[...])&lt;br&gt;   ↓&lt;br&gt;BaseModel.get_table_enriched(table_name, enrich_with, columns)&lt;br&gt;   ↓&lt;br&gt;Silver Parquet data -> FilterEngine -> Rendered exhibit" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="1020" y="1055" width="910" height="135" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- TAB 6: UI Components &amp; Streamlit App -->
  <diagram id="ui-components" name="6. UI Components &amp; Streamlit">
    <mxGraphModel dx="2400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title-ui" value="UI Components &amp; Streamlit App - Interactive Notebook Vault" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#00796b;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="2000" height="50" as="geometry" />
        </mxCell>

        <!-- NotebookVaultApp Class -->
        <mxCell id="app-class" value="&lt;b&gt;NotebookVaultApp&lt;/b&gt;&lt;br&gt;&lt;i&gt;app/ui/notebook_app_duckdb.py (905 lines)&lt;/i&gt;" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=70;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#e0f2f1;strokeColor=#00796b;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="950" height="700" as="geometry" />
        </mxCell>

        <mxCell id="app-attrs" value="&lt;b&gt;# ATTRIBUTES&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ notebooks: Dict[str, Tuple]  # notebook_id -> (path, config)&lt;br&gt;+ managers: Dict[str, NotebookManager]  # notebook_id -> manager&lt;br&gt;+ universal_session: UniversalSession" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=10;" vertex="1" parent="app-class">
          <mxGeometry y="70" width="950" height="90" as="geometry" />
        </mxCell>

        <mxCell id="app-line" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;strokeColor=#00796b;" vertex="1" parent="app-class">
          <mxGeometry y="160" width="950" height="8" as="geometry" />
        </mxCell>

        <mxCell id="app-methods" value="&lt;b&gt;# METHODS (16 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ run() - Main app entry point&lt;br&gt;&lt;br&gt;&lt;i&gt;## UI Rendering (13 methods)&lt;/i&gt;&lt;br&gt;- _render_header()&lt;br&gt;  # Render app header with logo and title&lt;br&gt;&lt;br&gt;- _render_folder_filter_editor()&lt;br&gt;  # Render folder filter context editor UI&lt;br&gt;&lt;br&gt;- _render_filters(notebook_config)&lt;br&gt;  # Render dynamic filters based on notebook config&lt;br&gt;&lt;br&gt;- _render_filter_editor()&lt;br&gt;  # Render filter editor panel in sidebar&lt;br&gt;&lt;br&gt;- _render_main_content()&lt;br&gt;  # Render main content area (notebooks or graph viewer)&lt;br&gt;&lt;br&gt;- _render_graph_viewer()&lt;br&gt;  # Render model graph visualization&lt;br&gt;&lt;br&gt;- _render_notebook_content(notebook_tuple)&lt;br&gt;  # Render notebook content (exhibits + markdown)&lt;br&gt;&lt;br&gt;- _render_edit_mode(notebook_id, notebook_path, notebook_config)&lt;br&gt;  # Render edit mode for notebook (YAML editor)&lt;br&gt;&lt;br&gt;- _render_view_mode(notebook_id, notebook_config)&lt;br&gt;  # Render view mode for notebook (exhibits)&lt;br&gt;&lt;br&gt;- _render_welcome()&lt;br&gt;  # Render welcome screen&lt;br&gt;&lt;br&gt;&lt;i&gt;## Utilities (3 methods)&lt;/i&gt;&lt;br&gt;- _get_available_tickers() -> List[str]&lt;br&gt;- _get_active_notebook() -> Optional[Tuple]&lt;br&gt;- _render_filter_context_info_OLD() [DEPRECATED]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="app-class">
          <mxGeometry y="168" width="950" height="450" as="geometry" />
        </mxCell>

        <!-- Exhibit Renderers -->
        <mxCell id="renderers-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#6a1b9a;" vertex="1" parent="1">
          <mxGeometry x="1100" y="100" width="850" height="700" as="geometry" />
        </mxCell>
        <mxCell id="renderers-title" value="📊 Exhibit Renderers - Visualization Components" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#6a1b9a" vertex="1" parent="1">
          <mxGeometry x="1120" y="115" width="700" height="35" as="geometry" />
        </mxCell>
        <mxCell id="renderers-text" value="&lt;b&gt;BaseExhibitRenderer (abstract)&lt;/b&gt;&lt;br&gt;app/ui/components/exhibits/base_renderer.py&lt;br&gt;&lt;br&gt;+ __init__(session: UniversalSession, notebook_manager: NotebookManager)&lt;br&gt;+ render(exhibit: Exhibit) -> None  [ABSTRACT]&lt;br&gt;- _get_data(exhibit: Exhibit) -> DataFrame&lt;br&gt;&lt;br&gt;───────────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;1. LineChartRenderer&lt;/b&gt;&lt;br&gt;app/ui/components/exhibits/line_chart.py&lt;br&gt;&lt;br&gt;+ render(exhibit: Exhibit) -> None&lt;br&gt;  # Render interactive line chart using Plotly&lt;br&gt;  # Supports: multiple y-axes, color grouping, dynamic legends&lt;br&gt;&lt;br&gt;───────────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;2. BarChartRenderer&lt;/b&gt;&lt;br&gt;app/ui/components/exhibits/bar_chart.py&lt;br&gt;&lt;br&gt;+ render(exhibit: Exhibit) -> None&lt;br&gt;  # Render bar chart using Plotly&lt;br&gt;  # Supports: grouped bars, stacked bars, horizontal/vertical&lt;br&gt;&lt;br&gt;───────────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;3. DataTableRenderer&lt;/b&gt;&lt;br&gt;app/ui/components/exhibits/data_table.py&lt;br&gt;&lt;br&gt;+ render(exhibit: Exhibit) -> None&lt;br&gt;  # Render interactive data table&lt;br&gt;  # Supports: pagination, sorting, searching, download&lt;br&gt;&lt;br&gt;───────────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;4. MetricCardsRenderer&lt;/b&gt;&lt;br&gt;app/ui/components/exhibits/metric_cards.py&lt;br&gt;&lt;br&gt;+ render(exhibit: Exhibit) -> None&lt;br&gt;  # Render metric cards (KPIs)&lt;br&gt;  # Shows: value, label, delta, trend&lt;br&gt;&lt;br&gt;───────────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;5. WeightedAggregateChartRenderer&lt;/b&gt;&lt;br&gt;app/ui/components/exhibits/weighted_aggregate_chart.py&lt;br&gt;&lt;br&gt;+ render(exhibit: Exhibit) -> None&lt;br&gt;  # Render weighted aggregate chart&lt;br&gt;  # Calculate weighted averages/sums&lt;br&gt;&lt;br&gt;───────────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;6. ForecastChartRenderer&lt;/b&gt;&lt;br&gt;app/ui/components/exhibits/forecast_chart.py&lt;br&gt;&lt;br&gt;+ render(exhibit: Exhibit) -> None&lt;br&gt;  # Render forecast with confidence intervals&lt;br&gt;&lt;br&gt;&lt;b&gt;Total: 6 exhibit renderers + base class&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="1120" y="160" width="810" height="625" as="geometry" />
        </mxCell>

        <!-- UI Flow -->
        <mxCell id="ui-flow-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="80" y="850" width="1870" height="350" as="geometry" />
        </mxCell>
        <mxCell id="ui-flow-title" value="🔄 UI Rendering Flow - User -> Streamlit -> Exhibit" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#e65100" vertex="1" parent="1">
          <mxGeometry x="100" y="865" width="800" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ui-flow-text" value="1. User opens browser -> Streamlit app loads&lt;br&gt;   ↓&lt;br&gt;2. NotebookVaultApp.__init__() -> Initialize session, discover notebooks&lt;br&gt;   ↓&lt;br&gt;3. NotebookVaultApp.run() -> Main app loop&lt;br&gt;   ├─ _render_header() -> Logo + title&lt;br&gt;   ├─ Sidebar:&lt;br&gt;   │  ├─ Notebook selector dropdown&lt;br&gt;   │  ├─ _render_filter_editor() -> Dynamic filters UI&lt;br&gt;   │  └─ Model graph viewer toggle&lt;br&gt;   └─ Main content area&lt;br&gt;&lt;br&gt;4. User selects notebook -> _get_active_notebook()&lt;br&gt;   ↓&lt;br&gt;5. _render_notebook_content(notebook_tuple)&lt;br&gt;   ├─ Load NotebookConfig&lt;br&gt;   ├─ Initialize NotebookManager&lt;br&gt;   └─ _render_view_mode(notebook_id, notebook_config)&lt;br&gt;&lt;br&gt;6. _render_view_mode() iterates through content_blocks:&lt;br&gt;   ├─ Markdown blocks -> st.markdown()&lt;br&gt;   ├─ Exhibit blocks:&lt;br&gt;   │  ├─ manager.get_exhibit_data(exhibit_id) -> DataFrame&lt;br&gt;   │  ├─ Select renderer based on exhibit.type&lt;br&gt;   │  └─ renderer.render(exhibit) -> Plotly chart / table / metrics&lt;br&gt;   └─ Collapsible sections -> st.expander()&lt;br&gt;&lt;br&gt;7. User changes filter -> Streamlit rerun -> Step 5 repeats with new filters&lt;br&gt;&lt;br&gt;&lt;b&gt;Renderer Selection (Strategy Pattern):&lt;/b&gt;&lt;br&gt;renderers = {&lt;br&gt;    ExhibitType.LINE_CHART: LineChartRenderer,&lt;br&gt;    ExhibitType.BAR_CHART: BarChartRenderer,&lt;br&gt;    ExhibitType.DATA_TABLE: DataTableRenderer,&lt;br&gt;    ExhibitType.METRIC_CARDS: MetricCardsRenderer,&lt;br&gt;    ExhibitType.WEIGHTED_AGGREGATE: WeightedAggregateChartRenderer,&lt;br&gt;    ExhibitType.FORECAST_CHART: ForecastChartRenderer&lt;br&gt;}&lt;br&gt;renderer = renderers[exhibit.type](session, manager)&lt;br&gt;renderer.render(exhibit)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="100" y="910" width="1830" height="280" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

