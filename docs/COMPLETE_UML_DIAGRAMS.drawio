        <!-- Ingestor Attributes -->
        <mxCell id="ingestor-attrs" value="&lt;b&gt;# ATTRIBUTES&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ alpha_vantage_cfg: Dict[str, Any]&lt;br&gt;+ registry: AlphaVantageRegistry&lt;br&gt;+ key_pool: ApiKeyPool&lt;br&gt;+ http: HttpClient&lt;br&gt;+ sink: BronzeSink&lt;br&gt;+ spark: SparkSession&lt;br&gt;- _http_lock: threading.Lock" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=10;" vertex="1" parent="ingestor-class">
          <mxGeometry y="70" width="850" height="140" as="geometry" />
        </mxCell>

        <mxCell id="ingestor-line1" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;strokeColor=#1976d2;" vertex="1" parent="ingestor-class">
          <mxGeometry y="210" width="850" height="8" as="geometry" />
        </mxCell>

        <!-- Ingestor Methods -->
        <mxCell id="ingestor-methods" value="&lt;b&gt;# METHODS (7 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ __init__(alpha_vantage_cfg, storage_cfg, spark)&lt;br&gt;  # Initialize ingestor with config and dependencies&lt;br&gt;&lt;br&gt;- _fetch_calls(calls, response_key=None) → List[List[Dict]]&lt;br&gt;  # Fetch data from API (sequential for rate limiting)&lt;br&gt;&lt;br&gt;- _fetch_calls_concurrent(calls, response_key, max_workers=5) → List[List[Dict]]&lt;br&gt;  # Concurrent fetching (for premium tier)&lt;br&gt;&lt;br&gt;+ ingest_reference_data(tickers, table_name='securities_reference', use_concurrent=False)&lt;br&gt;  # Ingest company overview data to Bronze&lt;br&gt;  # Pipeline: API → Facet.normalize → Facet.postprocess → Facet.validate → BronzeSink&lt;br&gt;&lt;br&gt;+ ingest_prices(tickers, date_from, date_to, table_name='securities_prices_daily', use_concurrent=False)&lt;br&gt;  # Ingest daily OHLCV data to Bronze&lt;br&gt;&lt;br&gt;+ ingest_bulk_listing(table_name='securities_reference', state='active')&lt;br&gt;  # Ingest bulk ticker listings from Alpha Vantage&lt;br&gt;&lt;br&gt;+ run_all(tickers, date_from, date_to, use_concurrent=False)&lt;br&gt;  # Run complete ingestion (reference + prices)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="ingestor-class">
          <mxGeometry y="218" width="850" height="310" as="geometry" />
        </mxCell>

        <!-- Rate Limiting Info -->
        <mxCell id="ingestor-rate-limit" value="&lt;b&gt;# RATE LIMITING STRATEGY&lt;/b&gt;&lt;br&gt;&lt;br&gt;Free Tier: 5 calls/min = 0.08333 calls/sec&lt;br&gt;Premium: 75 calls/min = 1.25 calls/sec&lt;br&gt;Strategy: Sequential processing by default" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;fillColor=#fff3e0;" vertex="1" parent="ingestor-class">
          <mxGeometry y="528" width="850" height="100" as="geometry" />
        </mxCell>

