        <mxCell id="msg1-label" value="1: ingest_reference_data(tickers=['AAPL', 'MSFT'])" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;fontColor=#1976d2;" vertex="1" parent="1">
