        <!-- AlphaVantageIngestor Class -->
        <mxCell id="ingestor-class" value="&lt;b&gt;AlphaVantageIngestor&lt;/b&gt;&lt;br&gt;&lt;i&gt;datapipelines/providers/alpha_vantage/alpha_vantage_ingestor.py (592 lines)&lt;/i&gt;" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=70;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=14;" vertex="1" parent="1">
