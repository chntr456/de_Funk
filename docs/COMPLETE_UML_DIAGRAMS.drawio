        <!-- BaseModel Class (1,313 lines) -->
        <mxCell id="basemodel-class" value="&lt;b&gt;&lt;&lt;abstract&gt;&gt;&lt;br&gt;BaseModel&lt;/b&gt;&lt;br&gt;&lt;i&gt;models/base/model.py (1,313 lines)&lt;/i&gt;" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=70;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=14;" vertex="1" parent="1">
