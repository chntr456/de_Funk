        <!-- Methods Section 1: Initialization & Properties -->
        <mxCell id="basemodel-init" value="&lt;b&gt;## INITIALIZATION &amp; PROPERTIES (6 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ __init__(connection, storage_cfg, model_cfg, params=None, repo_root=None)&lt;br&gt;  # Initialize model with configuration&lt;br&gt;&lt;br&gt;+ @property backend() → str&lt;br&gt;  # Get backend type (spark or duckdb)&lt;br&gt;&lt;br&gt;+ @property measures() → MeasureExecutor&lt;br&gt;  # Get unified measure executor (lazy-loaded)&lt;br&gt;&lt;br&gt;+ @property query_planner() → GraphQueryPlanner&lt;br&gt;  # Get query planner for dynamic joins (lazy-loaded)&lt;br&gt;&lt;br&gt;+ @property python_measures() → Optional[Any]&lt;br&gt;  # Get Python measures module (lazy-loaded)&lt;br&gt;&lt;br&gt;- _detect_backend() → str&lt;br&gt;  # Detect backend type from connection" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="basemodel-class">
          <mxGeometry y="358" width="900" height="190" as="geometry" />
        </mxCell>

        <!-- Methods Section 2: Graph Building -->
        <mxCell id="basemodel-graph" value="&lt;b&gt;## GRAPH BUILDING (5 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ build() → Tuple[Dict[str, DataFrame], Dict[str, DataFrame]]&lt;br&gt;  # Build model tables from Bronze layer&lt;br&gt;  # Returns: (dimensions, facts)&lt;br&gt;&lt;br&gt;- _build_nodes() → Dict[str, DataFrame]&lt;br&gt;  # Build all nodes from graph.nodes config&lt;br&gt;  # Loads from Bronze, applies select/derive/filters&lt;br&gt;&lt;br&gt;- _load_bronze_table(table_name: str) → DataFrame&lt;br&gt;  # Load Bronze table using StorageRouter&lt;br&gt;&lt;br&gt;- _apply_derive(df, col_name, expr, node_id) → DataFrame&lt;br&gt;  # Apply derive expression (SHA1, SQL expressions)&lt;br&gt;  # Supports: column refs, sha1(), window functions&lt;br&gt;&lt;br&gt;- _resolve_node(node_id, nodes) → DataFrame&lt;br&gt;  # Resolve node DataFrame (supports cross-model refs)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="basemodel-class">
          <mxGeometry y="548" width="900" height="200" as="geometry" />
        </mxCell>

        <!-- Methods Section 3: Backend Abstraction -->
        <mxCell id="basemodel-backend" value="&lt;b&gt;## BACKEND ABSTRACTION (2 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;- _select_columns(df, select_config) → DataFrame&lt;br&gt;  # Backend-agnostic column selection&lt;br&gt;  # Handles both Spark (F.col) and DuckDB (project)&lt;br&gt;&lt;br&gt;- _apply_filters(df, filters) → DataFrame&lt;br&gt;  # Backend-agnostic filter application&lt;br&gt;  # Spark: F.expr(), DuckDB: filter()" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="basemodel-class">
          <mxGeometry y="748" width="900" height="110" as="geometry" />
        </mxCell>

        <!-- Methods Section 4: Table Access -->
        <mxCell id="basemodel-table-access" value="&lt;b&gt;## TABLE ACCESS (9 methods)&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ ensure_built() → None&lt;br&gt;  # Lazy build pattern - only build when needed&lt;br&gt;&lt;br&gt;+ get_table(table_name) → DataFrame&lt;br&gt;  # Get table by name (searches dims and facts)&lt;br&gt;&lt;br&gt;+ get_table_enriched(table_name, enrich_with=None, columns=None) → DataFrame&lt;br&gt;  # Get table with dynamic joins via graph edges&lt;br&gt;&lt;br&gt;+ get_dimension_df(dim_id) → DataFrame&lt;br&gt;  # Get dimension table by ID&lt;br&gt;&lt;br&gt;+ get_fact_df(fact_id) → DataFrame&lt;br&gt;  # Get fact table by ID&lt;br&gt;&lt;br&gt;+ has_table(table_name) → bool&lt;br&gt;  # Check if table exists&lt;br&gt;&lt;br&gt;+ list_tables() → Dict[str, List[str]]&lt;br&gt;  # List all available tables {'dimensions': [...], 'facts': [...]}&lt;br&gt;&lt;br&gt;+ get_table_schema(table_name) → Dict[str, str]&lt;br&gt;  # Get schema (column definitions) for table&lt;br&gt;&lt;br&gt;+ set_session(session) → None&lt;br&gt;  # Inject session reference for cross-model access" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Courier New;fontSize=9;" vertex="1" parent="basemodel-class">
          <mxGeometry y="858" width="900" height="260" as="geometry" />
