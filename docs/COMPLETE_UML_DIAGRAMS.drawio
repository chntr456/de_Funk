        <mxCell id="note-filter" value="FilterEngine applies:&lt;br&gt;• ticker IN ['AAPL', 'MSFT']&lt;br&gt;• date &gt;= '2024-01-01'" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=8;align=left;" vertex="1" parent="1">
