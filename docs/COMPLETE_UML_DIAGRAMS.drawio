        <mxCell id="msg-nb12-label" value="12: Create Plotly figure" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;fontColor=#c2185b;" vertex="1" parent="1">
