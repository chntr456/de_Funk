        <mxCell id="facets-title" value="🔄 Facet Transformation Classes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#7b1fa2" vertex="1" parent="1">
          <mxGeometry x="1020" y="115" width="400" height="35" as="geometry" />
        </mxCell>
        <mxCell id="facets-text" value="&lt;b&gt;SecuritiesReferenceFacet&lt;/b&gt;&lt;br&gt;Transform company overview → securities_reference schema&lt;br&gt;&lt;br&gt;+ normalize(raw_data: List[Dict]) → DataFrame&lt;br&gt;  # Convert API JSON → Spark/DuckDB DataFrame&lt;br&gt;&lt;br&gt;+ postprocess(df: DataFrame) → DataFrame&lt;br&gt;  # Extract CIK, generate company_id (COMPANY_+10-digit-CIK)&lt;br&gt;  # Parse shares_outstanding, market_cap&lt;br&gt;  # Add snapshot_dt, asset_type='stocks'&lt;br&gt;&lt;br&gt;+ validate(df: DataFrame) → DataFrame&lt;br&gt;  # Validate schema, check required fields&lt;br&gt;  # Log warnings for missing data&lt;br&gt;&lt;br&gt;─────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;SecuritiesPricesFacet&lt;/b&gt;&lt;br&gt;Transform daily prices → securities_prices_daily schema&lt;br&gt;&lt;br&gt;+ normalize(raw_data: List[Dict]) → DataFrame&lt;br&gt;  # Convert API JSON → DataFrame&lt;br&gt;&lt;br&gt;+ postprocess(df: DataFrame) → DataFrame&lt;br&gt;  # Parse trade_date (YYYY-MM-DD)&lt;br&gt;  # Type conversions: open/high/low/close/volume → numeric&lt;br&gt;  # Calculate volume_weighted price&lt;br&gt;  # Add asset_type='stocks'&lt;br&gt;&lt;br&gt;+ validate(df: DataFrame) → DataFrame&lt;br&gt;  # Validate OHLCV schema&lt;br&gt;  # Check date ranges, price sanity&lt;br&gt;&lt;br&gt;─────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;Memory Bottleneck (IDENTIFIED ISSUE):&lt;/b&gt;&lt;br&gt;⚠ postprocess() converts entire DataFrame to Pandas&lt;br&gt;⚠ For 100 tickers × 20 years = 500K+ rows in memory&lt;br&gt;💡 Solution: Streaming writes with chunk processing" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="1020" y="160" width="710" height="425" as="geometry" />
        </mxCell>

