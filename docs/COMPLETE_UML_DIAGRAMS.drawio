          <mxGeometry x="179" y="220" width="1" height="1350" as="geometry" />
        </mxCell>
        <mxCell id="exec-ingestor" value="" style="line;strokeWidth=2;html=1;strokeColor=#1976d2;dashed=1;" vertex="1" parent="1">
