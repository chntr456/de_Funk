        <mxCell id="example-code" value="from core.session.filters import FilterEngine&#xa;&#xa;# Define filters&#xa;filters = {&#xa;    'ticker': ['AAPL', 'MSFT'],&#xa;    'volume': {'min': 1000000},&#xa;    'trade_date': {'start': '2024-01-01'}&#xa;}&#xa;&#xa;# Apply with auto-detection&#xa;filtered = FilterEngine.apply_from_session(df, filters, session)&#xa;&#xa;# Or specify backend explicitly&#xa;filtered = FilterEngine.apply_filters(df, filters, 'spark')" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
