  <diagram id="graph" name="6. Graph-Based Architecture">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="graph-title" value="Graph-Based Model Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="284.5" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Subtitle -->
        <mxCell id="subtitle" value="Declarative YAML-driven graph with nodes, edges, and paths" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="284.5" y="55" width="600" height="25" as="geometry" />
        </mxCell>

        <!-- YAML Config Box -->
        <mxCell id="yaml-box" value="YAML Configuration (company.yaml)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="480" height="680" as="geometry" />
        </mxCell>

        <!-- graph: header -->
        <mxCell id="graph-header" value="graph:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="440" height="20" as="geometry" />
        </mxCell>

        <!-- nodes: section -->
        <mxCell id="nodes-section" value="  nodes:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="440" height="180" as="geometry" />
        </mxCell>
        <mxCell id="node1" value="    - id: dim_company&#xa;      from: bronze.ref_ticker&#xa;      select:&#xa;        ticker: ticker&#xa;        company_name: name&#xa;      derive:&#xa;        company_id: sha1(ticker)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="190" width="400" height="70" as="geometry" />
        </mxCell>
        <mxCell id="node2" value="    - id: fact_prices&#xa;      from: bronze.prices_daily&#xa;      select:&#xa;        trade_date: trade_date&#xa;        ticker: ticker&#xa;        close: close" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="265" width="400" height="60" as="geometry" />
        </mxCell>

        <!-- edges: section -->
        <mxCell id="edges-section" value="  edges:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;verticalAlign=top;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="440" height="120" as="geometry" />
        </mxCell>
        <mxCell id="edge1" value="    - from: fact_prices&#xa;      to: dim_company&#xa;      on: [&quot;ticker=ticker&quot;]&#xa;      type: many_to_one&#xa;      description: &quot;Prices belong to company&quot;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="390" width="400" height="70" as="geometry" />
        </mxCell>

        <!-- paths: section -->
        <mxCell id="paths-section" value="  paths:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;verticalAlign=top;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="440" height="100" as="geometry" />
        </mxCell>
        <mxCell id="path1" value="    - id: prices_with_company&#xa;      hops: &quot;fact_prices -&gt; dim_company&quot;&#xa;      description: &quot;Joined view&quot;&#xa;      tags: [canonical, analytics]" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="530" width="400" height="50" as="geometry" />
        </mxCell>

        <!-- measures: section -->
        <mxCell id="measures-section" value="  measures:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;verticalAlign=top;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="440" height="140" as="geometry" />
        </mxCell>
        <mxCell id="measure1" value="    market_cap:&#xa;      description: &quot;Market cap proxy&quot;&#xa;      type: computed&#xa;      source: fact_prices.close&#xa;      expression: &quot;close * volume&quot;&#xa;      aggregation: avg" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="650" width="400" height="90" as="geometry" />
        </mxCell>

        <!-- 3-Phase Build Process -->
        <mxCell id="build-title" value="3-Phase Graph Building Process" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="580" y="100" width="550" height="30" as="geometry" />
        </mxCell>

        <!-- Phase 1 -->
        <mxCell id="phase1-box" value="PHASE 1: Build Nodes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="580" y="150" width="550" height="160" as="geometry" />
        </mxCell>
        <mxCell id="phase1-details" value="For each node in graph.nodes:&#xa;&#xa;1. Load from Bronze layer&#xa;   • StorageRouter.bronze_path(table_name)&#xa;   • BronzeTable.read() → DataFrame&#xa;&#xa;2. Apply 'select' transformations&#xa;   • Column selection and aliasing&#xa;&#xa;3. Apply 'derive' transformations&#xa;   • Computed columns (SHA1, concat, etc.)&#xa;&#xa;Result: nodes = {node_id: DataFrame, ...}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="600" y="180" width="510" height="120" as="geometry" />
        </mxCell>

        <!-- Arrow phase1 to phase2 -->
        <mxCell id="arrow-p1-p2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;endArrow=classic;endFill=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="phase1-box" target="phase2-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Phase 2 -->
        <mxCell id="phase2-box" value="PHASE 2: Validate Edges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="580" y="340" width="550" height="140" as="geometry" />
        </mxCell>
        <mxCell id="phase2-details" value="For each edge in graph.edges:&#xa;&#xa;1. Verify both nodes exist in nodes dict&#xa;&#xa;2. Extract join keys from 'on' specification&#xa;   • Parse: [&quot;ticker=ticker&quot;] → [(ticker, ticker)]&#xa;&#xa;3. Dry-run join validation&#xa;   • left.limit(1).join(right.limit(1))&#xa;   • Raises ValueError if join fails&#xa;&#xa;Result: All edges validated ✓" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="600" y="370" width="510" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow phase2 to phase3 -->
        <mxCell id="arrow-p2-p3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;endArrow=classic;endFill=1;strokeColor=#82b366;" edge="1" parent="1" source="phase2-box" target="phase3-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Phase 3 -->
        <mxCell id="phase3-box" value="PHASE 3: Materialize Paths" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="580" y="510" width="550" height="160" as="geometry" />
        </mxCell>
        <mxCell id="phase3-details" value="For each path in graph.paths:&#xa;&#xa;1. Parse hops specification&#xa;   • &quot;fact_prices -&gt; dim_company -&gt; dim_exchange&quot;&#xa;&#xa;2. Execute sequential joins&#xa;   • Start: df = nodes[first_hop]&#xa;   • For each hop: left_join(df, nodes[next], on=edge_keys)&#xa;   • Handle column deduplication (prefix duplicates)&#xa;&#xa;3. Store materialized view&#xa;   • paths[path_id] = joined_df&#xa;&#xa;Result: paths = {path_id: DataFrame, ...}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="600" y="540" width="510" height="120" as="geometry" />
        </mxCell>

        <!-- Final Result -->
