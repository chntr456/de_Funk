        <mxCell id="notes-title" value="📝 ERD NOTES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#e65100" vertex="1" parent="1">
          <mxGeometry x="1620" y="140" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="notes-text" value="&lt;b&gt;v2.0 Architecture Highlights:&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;Unified Bronze Layer&lt;/b&gt;:&lt;br&gt;  - securities_reference (all asset types)&lt;br&gt;  - securities_prices_daily (all asset types)&lt;br&gt;  - Partitioned by: snapshot_dt, asset_type (reference)&lt;br&gt;  - Partitioned by: trade_date, asset_type (prices)&lt;br&gt;&lt;br&gt;• &lt;b&gt;CIK Integration&lt;/b&gt;:&lt;br&gt;  - CIK = SEC's permanent company identifier&lt;br&gt;  - company_id = CONCAT('COMPANY_', cik)&lt;br&gt;  - Links stocks to companies via company_id&lt;br&gt;  - Immune to ticker changes (GOOGL→GOOG, FB→META)&lt;br&gt;&lt;br&gt;• &lt;b&gt;Modular YAML Architecture&lt;/b&gt;:&lt;br&gt;  - model.yaml (metadata &amp; composition)&lt;br&gt;  - schema.yaml (dimensions &amp; facts)&lt;br&gt;  - graph.yaml (nodes, edges, paths)&lt;br&gt;  - measures.yaml (YAML + Python measures)&lt;br&gt;&lt;br&gt;• &lt;b&gt;Inheritance System&lt;/b&gt;:&lt;br&gt;  - _base/securities templates&lt;br&gt;  - 'extends' keyword for component inheritance&lt;br&gt;  - 'inherits_from' for model-level inheritance&lt;br&gt;  - 100% field inheritance + additions/overrides&lt;br&gt;&lt;br&gt;• &lt;b&gt;Storage Patterns&lt;/b&gt;:&lt;br&gt;  - All data in Parquet files&lt;br&gt;  - DuckDB catalog (analytics.db) = metadata only&lt;br&gt;  - No data duplication (queries read Parquet)&lt;br&gt;&lt;br&gt;• &lt;b&gt;Model Status&lt;/b&gt;:&lt;br&gt;  ✅ COMPLETE: Core, Company, Stocks&lt;br&gt;  ⚠️ PARTIAL: Options (schema only)&lt;br&gt;  📋 SKELETON: ETFs, Futures&lt;br&gt;  🗑️ DEPRECATED: Equity, Corporate&lt;br&gt;&lt;br&gt;• &lt;b&gt;Data Sources (v2.0)&lt;/b&gt;:&lt;br&gt;  - Alpha Vantage (sole securities provider)&lt;br&gt;  - Polygon.io REMOVED completely&lt;br&gt;  - BLS (economic indicators)&lt;br&gt;  - Chicago Data Portal (municipal data)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New;fontColor=#333333" vertex="1" parent="1">
          <mxGeometry x="1620" y="180" width="640" height="500" as="geometry" />
        </mxCell>

        <!-- Bronze Layer Reference Box -->
        <mxCell id="bronze-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="1">
          <mxGeometry x="1600" y="720" width="680" height="280" as="geometry" />
        </mxCell>
        <mxCell id="bronze-title" value="📦 BRONZE LAYER TABLES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#388e3c" vertex="1" parent="1">
          <mxGeometry x="1620" y="730" width="350" height="30" as="geometry" />
        </mxCell>
        <mxCell id="bronze-text" value="&lt;b&gt;1. securities_reference&lt;/b&gt;&lt;br&gt;   Columns: ticker, name, asset_type, cik, exchange_code,&lt;br&gt;            shares_outstanding, market_cap, snapshot_dt, ...&lt;br&gt;   Partitions: snapshot_dt, asset_type&lt;br&gt;   Asset Types: stocks, options, etfs, futures&lt;br&gt;   Path: storage/bronze/securities_reference/&lt;br&gt;         snapshot_dt=2025-11-21/asset_type=stocks/&lt;br&gt;&lt;br&gt;&lt;b&gt;2. securities_prices_daily&lt;/b&gt;&lt;br&gt;   Columns: ticker, trade_date, asset_type, open, high,&lt;br&gt;            low, close, volume, volume_weighted, ...&lt;br&gt;   Partitions: asset_type, year, month&lt;br&gt;   Asset Types: stocks, options, etfs, futures&lt;br&gt;   Path: storage/bronze/securities_prices_daily/&lt;br&gt;         asset_type=stocks/year=2025/month=11/&lt;br&gt;&lt;br&gt;&lt;b&gt;Benefits:&lt;/b&gt;&lt;br&gt;• No data duplication at ingestion&lt;br&gt;• Bronze mirrors API structure&lt;br&gt;• Easy to add new asset types&lt;br&gt;• Single ingestion pipeline for all securities" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;fontColor=#333333" vertex="1" parent="1">
          <mxGeometry x="1620" y="770" width="640" height="220" as="geometry" />
        </mxCell>

        <!-- Model Count Summary -->
        <mxCell id="summary-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;" vertex="1" parent="1">
          <mxGeometry x="1600" y="1030" width="680" height="140" as="geometry" />
        </mxCell>
        <mxCell id="summary-title" value="📊 MODEL STATISTICS" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1976d2" vertex="1" parent="1">
          <mxGeometry x="1620" y="1040" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="summary-text" value="• Total Models: 8 (Core, Company, Stocks, Options, ETFs, Futures, Macro, City Finance)&lt;br&gt;• Total Dimensions: 20+ master tables&lt;br&gt;• Total Facts: 25+ transaction tables&lt;br&gt;• Total Measures: 70+ (YAML + Python)&lt;br&gt;• Python Measures: 6 in Stocks (sharpe_ratio, volatility, beta, alpha, correlation, rolling_returns)&lt;br&gt;• Cross-Model Relationships: 12+ joins (company→stocks, stocks→options, calendar→all facts)&lt;br&gt;• Storage Format: Parquet (columnar, compressed)&lt;br&gt;• Query Engine: DuckDB (10-100x faster than Spark for analytics)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New;fontColor=#333333" vertex="1" parent="1">
          <mxGeometry x="1620" y="1080" width="640" height="80" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

