# de_Funk Environment Configuration
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env to git!

# ============================================================================
# POLYGON.IO API KEYS
# ============================================================================
# Get your API key from: https://polygon.io/dashboard/api-keys
# You can provide multiple keys separated by commas for better rate limiting
POLYGON_API_KEYS=your_polygon_api_key_here

# ============================================================================
# BUREAU OF LABOR STATISTICS (BLS) API KEY
# ============================================================================
# Register for a free API key at: https://data.bls.gov/registrationEngine/
# Free tier: 500 queries/day, 20 years of data per query
BLSAPI_KEYS=your_bls_api_key_here

# ============================================================================
# CHICAGO DATA PORTAL (SOCRATA) API KEYS
# ============================================================================
# Get your app token from: https://data.cityofchicago.org/profile/app_tokens
# Optional but recommended for higher rate limits
CHICAGO_API_KEYS=your_chicago_app_token_here

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
# Connection type: 'spark' or 'duckdb'
# CONNECTION_TYPE=duckdb

# ============================================================================
# OPTIONAL: ADDITIONAL CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Spark configuration (if using Spark)
# SPARK_DRIVER_MEMORY=4g
# SPARK_EXECUTOR_MEMORY=2g
