# de_Funk Environment Configuration
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env to git!

# ============================================================================
# ALPHA VANTAGE API KEYS (v2.0)
# ============================================================================
# Get your free API key from: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5 requests/minute
# Premium tier: 75 requests/minute, 750 requests/day
# You can provide multiple keys separated by commas for key rotation (premium)
ALPHA_VANTAGE_API_KEYS=your_alpha_vantage_api_key_here

# ============================================================================
# BUREAU OF LABOR STATISTICS (BLS) API KEY
# ============================================================================
# Register for a free API key at: https://data.bls.gov/registrationEngine/
# Free tier: 500 queries/day, 20 years of data per query
BLSAPI_KEYS=your_bls_api_key_here

# ============================================================================
# CHICAGO DATA PORTAL (SOCRATA) API KEYS
# ============================================================================
# Get your app token from: https://data.cityofchicago.org/profile/app_tokens
# Optional but recommended for higher rate limits
CHICAGO_API_KEYS=your_chicago_app_token_here

# ============================================================================
# DATABASE CONNECTION CONFIGURATION
# ============================================================================
# Connection type: 'spark' or 'duckdb' (default: duckdb)
# Precedence: env var > storage.json > default
CONNECTION_TYPE=duckdb

# ============================================================================
# SPARK CONFIGURATION (when using Spark connection)
# ============================================================================
# Memory settings for Spark driver and executors
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g

# Number of shuffle partitions (affects parallelism)
# SPARK_SHUFFLE_PARTITIONS=200

# Timezone for Spark SQL operations
# SPARK_TIMEZONE=UTC

# Use legacy time parser policy (true/false)
# SPARK_LEGACY_TIME_PARSER=true

# ============================================================================
# DUCKDB CONFIGURATION (when using DuckDB connection)
# ============================================================================
# Path to DuckDB database file (relative to repo root or absolute)
# DUCKDB_PATH=storage/duckdb/analytics.db

# Memory limit for DuckDB
# DUCKDB_MEMORY_LIMIT=4GB

# Number of threads for DuckDB
# DUCKDB_THREADS=4

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
