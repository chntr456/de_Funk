{
  "_migration_note": "v2.6: Bronze table configs being migrated to endpoint markdown files. See Data Sources/Storage Routing.md for overview. Tables below remain for backwards compatibility.",
  "connection": {
    "type": "duckdb",
    "comment": "Default for UI only (10-100x faster). All data pipelines (ingestion + model builds) override to 'spark'. Set CONNECTION_TYPE env var to override."
  },
  "defaults": {
    "format": "delta",
    "comment": "Delta Lake is the default storage format for all Bronze and Silver tables. Provides ACID transactions, time travel, and schema evolution."
  },
  "roots": {
    "bronze": "storage/bronze",
    "silver": "storage/silver",
    "core_silver": "storage/silver/core",

    "_comment_v2": "v2.0 model roots (modular architecture)",
    "company_silver": "storage/silver/company",
    "stocks_silver": "storage/silver/stocks",
    "options_silver": "storage/silver/options",
    "etfs_silver": "storage/silver/etfs",
    "futures_silver": "storage/silver/futures",

    "_comment_v1": "v1.x legacy model roots (will be deprecated)",
    "equity_silver": "storage/silver/equity",
    "corporate_silver": "storage/silver/corporate",
    "forecast_silver": "storage/silver/forecast",
    "macro_silver": "storage/silver/macro",
    "city_finance_silver": "storage/silver/city_finance"
  },
  "tables": {
    "calendar_seed":   { "root": "bronze", "rel": "calendar_seed", "partitions": [] },
    "ticker_seed":     { "root": "bronze", "rel": "ticker_seed", "partitions": ["asset_type"], "write_strategy": "overwrite", "comment": "Seeded tickers from LISTING_STATUS API" },

    "securities_reference": { "root": "bronze", "rel": "securities_reference", "partitions": ["asset_type"], "write_strategy": "upsert", "key_columns": ["ticker"], "comment": "v2.0 unified reference data - basic ticker info from LISTING_STATUS" },
    "company_reference": { "root": "bronze", "rel": "company_reference", "partitions": [], "write_strategy": "upsert", "key_columns": ["cik"], "comment": "v2.0 company data from OVERVIEW - CIK, sector, industry, market_cap (separate from securities to avoid overwrite issues)" },
    "securities_prices_daily": { "root": "bronze", "rel": "securities_prices_daily", "partitions": [], "write_strategy": "append", "key_columns": ["ticker", "trade_date"], "date_column": "trade_date", "comment": "v2.0 unified daily OHLCV - append strategy for immutable time-series (prevents O(N²) memory growth)" },

    "income_statements": { "root": "bronze", "rel": "income_statements", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"], "date_column": "fiscal_date_ending", "comment": "Alpha Vantage INCOME_STATEMENT" },
    "balance_sheets": { "root": "bronze", "rel": "balance_sheets", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"], "date_column": "fiscal_date_ending", "comment": "Alpha Vantage BALANCE_SHEET" },
    "cash_flows": { "root": "bronze", "rel": "cash_flows", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"], "date_column": "fiscal_date_ending", "comment": "Alpha Vantage CASH_FLOW" },
    "earnings": { "root": "bronze", "rel": "earnings", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"], "date_column": "fiscal_date_ending", "comment": "Alpha Vantage EARNINGS" },
    "historical_options": { "root": "bronze", "rel": "historical_options", "partitions": ["underlying_ticker", "expiration_date"], "comment": "Alpha Vantage HISTORICAL_OPTIONS" },

    "ref_all_tickers": { "root": "bronze", "rel": "ref_all_tickers", "partitions": [], "comment": "v1.x legacy - use securities_reference" },
    "exchanges":       { "root": "bronze", "rel": "exchanges",       "partitions": [] },
    "ref_ticker":      { "root": "bronze", "rel": "ref_ticker",      "partitions": [], "comment": "v1.x legacy - use securities_reference" },
    "prices_daily":    { "root": "bronze", "rel": "prices_daily",    "partitions": ["trade_date"], "comment": "v1.x legacy - use securities_prices_daily" },
    "news":            { "root": "bronze", "rel": "news",            "partitions": ["publish_date"] },
    "fundamentals":    { "root": "bronze", "rel": "fundamentals",    "partitions": ["fiscal_year","fiscal_period"] },

    "bls_unemployment":  { "root": "bronze", "rel": "bls/unemployment",  "partitions": ["year"] },
    "bls_cpi":           { "root": "bronze", "rel": "bls/cpi",           "partitions": ["year"] },
    "bls_employment":    { "root": "bronze", "rel": "bls/employment",    "partitions": ["year"] },
    "bls_wages":         { "root": "bronze", "rel": "bls/wages",         "partitions": ["year"] },

    "chicago_unemployment":     { "root": "bronze", "rel": "chicago/unemployment",     "partitions": ["date"] },
    "chicago_building_permits": { "root": "bronze", "rel": "chicago/building_permits", "partitions": ["issue_date"] },
    "chicago_business_licenses": { "root": "bronze", "rel": "chicago/business_licenses", "partitions": ["start_date"] },
    "chicago_economic_indicators": { "root": "bronze", "rel": "chicago/economic_indicators", "partitions": ["date"] },

    "dim_company":     { "root": "silver", "rel": "company/dims/dim_company" },
    "dim_exchange":    { "root": "silver", "rel": "company/dims/dim_exchange" },
    "fact_prices":     { "root": "silver", "rel": "company/facts/fact_prices" },
    "fact_news":       { "root": "silver", "rel": "company/facts/fact_news" },

    "prices_with_company": { "root": "silver", "rel": "company/facts/prices_with_company" },
    "news_with_company":   { "root": "silver", "rel": "company/facts/news_with_company" },

    "dim_equity":                  { "root": "equity_silver", "rel": "dims/dim_equity" },
    "fact_equity_prices":          { "root": "equity_silver", "rel": "facts/fact_equity_prices", "partitions": ["trade_date"] },
    "fact_equity_technicals":      { "root": "equity_silver", "rel": "facts/fact_equity_technicals", "partitions": ["trade_date"] },
    "fact_equity_news":            { "root": "equity_silver", "rel": "facts/fact_equity_news", "partitions": ["publish_date"] },
    "equity_prices_with_company":  { "root": "equity_silver", "rel": "facts/equity_prices_with_company", "partitions": ["trade_date"] },
    "equity_news_with_company":    { "root": "equity_silver", "rel": "facts/equity_news_with_company", "partitions": ["publish_date"] }
  }
}
