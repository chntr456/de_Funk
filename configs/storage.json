{
  "_migration_note": "v2.7: Bronze paths reorganized to provider/dataset format. All provider tables now under bronze/{provider}/{dataset}. See Data Sources/Storage Routing.md for overview.",
  "connection": {
    "type": "duckdb",
    "comment": "Default for UI only (10-100x faster). All data pipelines (ingestion + model builds) override to 'spark'. Set CONNECTION_TYPE env var to override."
  },
  "defaults": {
    "format": "delta",
    "comment": "Delta Lake is the default storage format for all Bronze and Silver tables. Provides ACID transactions, time travel, and schema evolution."
  },
  "roots": {
    "bronze": "storage/bronze",
    "silver": "storage/silver",

    "_comment_domains": "Domain-based silver roots",
    "securities_silver": "storage/silver/securities",
    "municipal_silver": "storage/silver/municipal"
  },
  "tables": {
    "_comment_seeds": "Seed tables (not provider-specific)",
    "calendar_seed": { "root": "bronze", "rel": "seeds/calendar", "partitions": [] },
    "ticker_seed": { "root": "bronze", "rel": "seeds/tickers", "partitions": [], "write_strategy": "overwrite", "comment": "Seeded tickers from LISTING_STATUS API" },

    "_comment_alpha_vantage": "Alpha Vantage provider tables (v2.7 - provider/dataset format)",
    "alpha_vantage/securities_reference": { "root": "bronze", "rel": "alpha_vantage/securities_reference", "partitions": ["asset_type"], "write_strategy": "upsert", "key_columns": ["ticker"] },
    "alpha_vantage/company_reference": { "root": "bronze", "rel": "alpha_vantage/company_reference", "partitions": [], "write_strategy": "upsert", "key_columns": ["cik"] },
    "alpha_vantage/prices_daily": { "root": "bronze", "rel": "alpha_vantage/prices_daily", "partitions": [], "write_strategy": "append", "key_columns": ["ticker", "trade_date"], "date_column": "trade_date" },
    "alpha_vantage/income_statements": { "root": "bronze", "rel": "alpha_vantage/income_statements", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"] },
    "alpha_vantage/balance_sheets": { "root": "bronze", "rel": "alpha_vantage/balance_sheets", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"] },
    "alpha_vantage/cash_flows": { "root": "bronze", "rel": "alpha_vantage/cash_flows", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"] },
    "alpha_vantage/earnings": { "root": "bronze", "rel": "alpha_vantage/earnings", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"] },
    "alpha_vantage/historical_options": { "root": "bronze", "rel": "alpha_vantage/historical_options", "partitions": ["underlying_ticker", "expiration_date"] },

    "_comment_chicago": "Chicago Data Portal provider tables (config in endpoint markdown)",
    "_note_chicago": "Tables defined in Data Sources/Endpoints/Chicago Data Portal/*.md",

    "_comment_cook_county": "Cook County Data Portal provider tables (config in endpoint markdown)",
    "_note_cook_county": "Tables defined in Data Sources/Endpoints/Cook County Data Portal/*.md",

    "_comment_silver": "Silver layer tables (domain-based)",
    "dim_calendar": { "root": "silver", "rel": "core/dims/dim_calendar" },
    "dim_stock": { "root": "securities_silver", "rel": "stocks/dims/dim_stock" },
    "fact_stock_prices": { "root": "securities_silver", "rel": "stocks/facts/fact_stock_prices" }
  }
}
