{
  "_migration_note": "v2.7: Bronze paths reorganized to provider/dataset format. All provider tables now under bronze/{provider}/{dataset}. See Data Sources/Storage Routing.md for overview.",
  "connection": {
    "type": "duckdb",
    "comment": "Default for UI only (10-100x faster). All data pipelines (ingestion + model builds) override to 'spark'. Set CONNECTION_TYPE env var to override."
  },
  "defaults": {
    "format": "delta",
    "comment": "Delta Lake is the default storage format for all Bronze and Silver tables. Provides ACID transactions, time travel, and schema evolution."
  },
  "roots": {
    "bronze": "storage/bronze",
    "silver": "storage/silver",

    "_comment_domains": "Domain-based silver roots",
    "securities_silver": "storage/silver/securities",
    "municipal_silver": "storage/silver/municipal"
  },
  "tables": {
    "_comment_seeds": "Seed tables (not provider-specific)",
    "calendar_seed": { "root": "bronze", "rel": "seeds/calendar", "partitions": [] },
    "ticker_seed": { "root": "bronze", "rel": "seeds/tickers", "partitions": [], "write_strategy": "overwrite", "comment": "Seeded tickers from LISTING_STATUS API" },

    "_comment_alpha_vantage": "Alpha Vantage provider tables (v2.7 - provider/endpoint_id format)",
    "alpha_vantage/listing_status": { "root": "bronze", "rel": "seeds/tickers", "partitions": [], "write_strategy": "overwrite", "key_columns": ["ticker"], "comment": "Ticker listings from LISTING_STATUS - stored in seeds/tickers" },
    "alpha_vantage/company_overview": { "root": "bronze", "rel": "alpha_vantage/company_overview", "partitions": [], "write_strategy": "upsert", "key_columns": ["cik"], "comment": "Company fundamentals from COMPANY_OVERVIEW endpoint" },
    "alpha_vantage/time_series_daily_adjusted": { "root": "bronze", "rel": "alpha_vantage/time_series_daily_adjusted", "partitions": [], "write_strategy": "append", "key_columns": ["ticker", "trade_date"], "date_column": "trade_date", "comment": "Daily OHLCV from TIME_SERIES_DAILY_ADJUSTED endpoint" },
    "alpha_vantage/income_statement": { "root": "bronze", "rel": "alpha_vantage/income_statement", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"], "comment": "Income statement from INCOME_STATEMENT endpoint" },
    "alpha_vantage/balance_sheet": { "root": "bronze", "rel": "alpha_vantage/balance_sheet", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"], "comment": "Balance sheet from BALANCE_SHEET endpoint" },
    "alpha_vantage/cash_flow": { "root": "bronze", "rel": "alpha_vantage/cash_flow", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"], "comment": "Cash flow from CASH_FLOW endpoint" },
    "alpha_vantage/earnings": { "root": "bronze", "rel": "alpha_vantage/earnings", "partitions": ["report_type"], "write_strategy": "upsert", "key_columns": ["ticker", "fiscal_date_ending", "report_type"], "comment": "Earnings from EARNINGS endpoint" },
    "alpha_vantage/historical_options": { "root": "bronze", "rel": "alpha_vantage/historical_options", "partitions": ["underlying_ticker", "expiration_date"] },

    "_comment_chicago": "Chicago Data Portal provider tables (config in endpoint markdown)",
    "_note_chicago": "Tables defined in Data Sources/Endpoints/Chicago Data Portal/*.md",

    "_comment_cook_county": "Cook County Data Portal provider tables (config in endpoint markdown)",
    "_note_cook_county": "Tables defined in Data Sources/Endpoints/Cook County Data Portal/*.md",

    "_comment_silver": "Silver layer tables (domain-based)",
    "dim_calendar": { "root": "silver", "rel": "core/dims/dim_calendar" },
    "dim_stock": { "root": "securities_silver", "rel": "stocks/dims/dim_stock" },
    "fact_stock_prices": { "root": "securities_silver", "rel": "stocks/facts/fact_stock_prices" }
  }
}
