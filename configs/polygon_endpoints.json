

{
  "credentials": {
    "api_keys": ["q6qHAGqgBoBNxeuQ5bjIXpBfKloYjaL5"]
  },
  "base_urls": { "core": "https://api.polygon.io" },
  "headers": { "Authorization": "Bearer ${API_KEY}" },
  "rate_limit_per_sec": 0.0834,
  "endpoints": {
    "prices_daily": {
      "base": "core",
      "method": "GET",
      "path_template": "/v2/aggs/ticker/{ticker}/range/{mult}/{timespan}/{from}/{to}",
      "required_params": ["ticker", "from", "to"],
      "default_path_params": { "mult": 1, "timespan": "day" },
      "default_query": { "adjusted": "true", "sort": "asc", "limit": 50000 },
      "response_key": "results"
    },
    "prices_daily_grouped": {
      "base": "core",
      "method": "GET",
      "path_template": "/v2/aggs/grouped/locale/us/market/stocks/{date}",
      "required_params": ["date"],
      "default_path_params": {},
      "default_query": { "adjusted": "true" },
      "response_key": "results"
    },
    "news": {
      "base": "core",
      "method": "GET",
      "path_template": "/v2/reference/news",
      "required_params": [],
      "default_path_params": {},
      "default_query": { "limit": 1000, "sort": "published_utc", "order": "asc" },
      "response_key": "results"
    },
    "fundamentals_ttm": {
      "base": "core",
      "method": "GET",
      "path_template": "/vX/reference/financials",
      "required_params": ["ticker"],
      "default_path_params": {},
      "default_query": { "period": "ttm", "limit": 1, "ticker": "{ticker}" },
      "response_key": "results"
    },
    "ref_ticker": {
      "base": "core",
      "method": "GET",
      "path_template": "/v3/reference/tickers/{ticker}",
      "required_params": ["ticker"],
      "default_path_params": {},
      "default_query": {},
      "response_key": "results"
    },
    "exchanges": {
      "base": "core",
      "method": "GET",
      "path_template": "/v3/reference/exchanges",
      "required_params": [],
      "default_path_params": {},
      "default_query": { "asset_class": "stocks", "limit": 1000 },
      "response_key": "results"
    }
  }
}
