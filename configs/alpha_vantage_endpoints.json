{
  "credentials": {
    "api_keys": [],
    "comment": "Set ALPHA_VANTAGE_API_KEYS environment variable with your API key(s)"
  },
  "base_urls": {
    "core": "https://www.alphavantage.co/query"
  },
  "headers": {},
  "rate_limit_per_sec": 1.0,
  "_rate_limit_comment": "Conservative rate: 60 calls/minute (1.0/sec) - provides headroom below premium tier limit (75/min). Free tier: 5 calls/minute (0.08333/sec).",
  "us_exchanges": ["NYSE", "NASDAQ", "NYSEAMERICAN", "NYSEMKT", "BATS", "NYSEARCA"],
  "_us_exchanges_comment": "Filter to US exchanges for company data ingestion. Foreign exchanges may not have OVERVIEW data available.",
  "endpoints": {
    "company_overview": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "OVERVIEW"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "Company fundamentals including sector, industry, market cap, PE ratio, etc. Note: No direct CIK field, but includes exchange and other identifiers."
    },
    "time_series_daily": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "TIME_SERIES_DAILY",
        "outputsize": "full",
        "datatype": "json"
      },
      "response_key": "Time Series (Daily)",
      "default_path_params": {},
      "comment": "Daily OHLCV data. outputsize: 'compact' (100 days) or 'full' (20+ years)"
    },
    "time_series_daily_adjusted": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "TIME_SERIES_DAILY_ADJUSTED",
        "outputsize": "full",
        "datatype": "json"
      },
      "response_key": "Time Series (Daily)",
      "default_path_params": {},
      "comment": "Daily OHLCV with dividend/split adjustments. Recommended for historical analysis."
    },
    "global_quote": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "GLOBAL_QUOTE"
      },
      "response_key": "Global Quote",
      "default_path_params": {},
      "comment": "Real-time quote with latest price, volume, change"
    },
    "symbol_search": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_query": ["keywords"],
      "default_query": {
        "function": "SYMBOL_SEARCH"
      },
      "response_key": "bestMatches",
      "default_path_params": {},
      "comment": "Search for ticker symbols by company name or ticker"
    },
    "listing_status": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": [],
      "default_query": {
        "function": "LISTING_STATUS",
        "state": "active"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "Get list of active or delisted stocks. Returns CSV format. Useful for bulk ticker discovery."
    },
    "technical_sma": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol", "interval", "time_period", "series_type"],
      "default_query": {
        "function": "SMA"
      },
      "response_key": "Technical Analysis: SMA",
      "default_path_params": {},
      "comment": "Simple Moving Average. interval: 1min, 5min, 15min, 30min, 60min, daily, weekly, monthly"
    },
    "technical_rsi": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol", "interval", "time_period", "series_type"],
      "default_query": {
        "function": "RSI"
      },
      "response_key": "Technical Analysis: RSI",
      "default_path_params": {},
      "comment": "Relative Strength Index"
    },
    "technical_macd": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol", "interval", "series_type"],
      "default_query": {
        "function": "MACD"
      },
      "response_key": "Technical Analysis: MACD",
      "default_path_params": {},
      "comment": "Moving Average Convergence Divergence"
    },
    "income_statement": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "INCOME_STATEMENT"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "Annual and quarterly income statements. Returns annualReports and quarterlyReports arrays with revenue, expenses, net income, etc."
    },
    "balance_sheet": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "BALANCE_SHEET"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "Annual and quarterly balance sheets with GAAP/IFRS normalized fields. Includes assets, liabilities, equity."
    },
    "cash_flow": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "CASH_FLOW"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "Annual and quarterly cash flow statements. Operating, investing, and financing cash flows."
    },
    "earnings": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "EARNINGS"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "Annual and quarterly earnings (EPS actual vs estimate, surprise percentage)."
    },
    "earnings_calendar": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": [],
      "default_query": {
        "function": "EARNINGS_CALENDAR",
        "horizon": "3month"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "Upcoming earnings announcements. Returns CSV format. horizon: 3month, 6month, 12month."
    },
    "historical_options": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "HISTORICAL_OPTIONS"
      },
      "response_key": "data",
      "default_path_params": {},
      "comment": "Historical options chain data including strike, expiry, bid/ask, Greeks, implied volatility. Premium endpoint."
    },
    "realtime_options": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "REALTIME_OPTIONS"
      },
      "response_key": "data",
      "default_path_params": {},
      "comment": "Real-time options chain data. Premium endpoint."
    },
    "etf_profile": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": ["symbol"],
      "default_query": {
        "function": "ETF_PROFILE"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "ETF profile including holdings, sector weights, expense ratio, AUM."
    },
    "top_gainers_losers": {
      "base": "core",
      "method": "GET",
      "path_template": "",
      "required_params": [],
      "default_query": {
        "function": "TOP_GAINERS_LOSERS"
      },
      "response_key": null,
      "default_path_params": {},
      "comment": "Top 20 gainers, losers, and most actively traded tickers. Useful for large-cap discovery."
    }
  }
}
